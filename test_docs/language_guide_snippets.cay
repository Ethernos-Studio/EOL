// language-guide.md 中的代码片段整合测试

public class MathHelper {
    public static int addNumbers(int a, int b) {
        return a + b;
    }
}

public int main() {
    // ========== 代码块5: 隐式类型转换 ==========
    int i = 100;
    long l = i;        // int -> long（扩大转换）
    float f = i;       // int -> float
    double d = f;      // float -> double
    
    // ========== 代码块6: 显式类型转换 ==========
    double d2 = 3.14;
    int i2 = (int)d2;    // double -> int（截断小数）
    
    long l2 = 1000;
    int j = (int)l2;    // long -> int（可能溢出）
    
    // ========== 代码块7: 类型转换方法 ==========
    // int -> String：使用 String.valueOf()
    int i3 = 42;
    String s = String.valueOf(i3);
    println("String value: " + s);
    
    // String -> int：使用 Integer.parseInt()
    int n = Integer.parseInt("123");
    println("Parsed int: " + n);
    
    // ========== 代码块10: 自增自减 ==========
    int a = 5;
    int b = ++a;   // 前置自增：a=6, b=6
    int c = a++;   // 后置自增：c=6, a=7
    println("a=" + a + ", b=" + b + ", c=" + c);
    
    // ========== 代码块11: 三元运算符 ==========
    int a2 = 10;
    int b2 = 20;
    int max = (a2 > b2) ? a2 : b2;  // max = 20
    println("max = " + max);
    
    // ========== 代码块12: if-else ==========
    int score = 85;
    
    if (score >= 90) {
        println("A");
    } else if (score >= 80) {
        println("B");
    } else if (score >= 70) {
        println("C");
    } else {
        println("D");
    }
    
    // ========== 代码块13: switch ==========
    int day = 3;
    
    switch (day) {
        case 1:
            println("Monday");
            break;
        case 2:
            println("Tuesday");
            break;
        case 3:
            println("Wednesday");
            break;
        default:
            println("Other day");
            break;
    }
    
    // ========== 代码块14: for 循环 ==========
    // 基本 for
    for (int k = 0; k < 5; k++) {
        println("k = " + k);
    }
    
    // 多变量声明 - 使用 while 循环替代
    int m = 0, n2 = 10;
    while (m < 5) {
        println("m=" + m + ", n=" + n2);
        m++;
        n2--;
    }
    
    // ========== 代码块15: while 循环 ==========
    int count = 0;
    while (count < 3) {
        println("Count: " + count);
        count++;
    }
    
    // ========== 代码块16: do-while ==========
    int num = 0;
    do {
        println("Number: " + num);
        num++;
    } while (num < 3);
    
    // ========== 代码块17: break 和 continue ==========
    for (int p = 0; p < 10; p++) {
        if (p == 3) continue;
        if (p == 7) break;
        println("p = " + p);
    }
    
    // ========== 代码块18: return ==========
    int result = MathHelper.addNumbers(5, 3);
    println("5 + 3 = " + result);
    
    return 0;
}
