public int main() {
    // 算术运算符
    int a = 10;
    int b = 3;
    println("a + b = " + (a + b));
    println("a - b = " + (a - b));
    println("a * b = " + (a * b));
    println("a / b = " + (a / b));
    println("a % b = " + (a % b));

    // 赋值运算符
    int x = 5;
    x += 3;  // x = 8
    x -= 2;  // x = 6
    x *= 2;  // x = 12
    x /= 3;  // x = 4
    x %= 3;  // x = 1

    // 自增/自减
    int c = 5;
    int d = ++c;   // 前置自增：c=6, d=6
    int e = c++;   // 后置自增：e=6, c=7

    // 比较运算符
    boolean eq = (a == b);
    boolean ne = (a != b);
    boolean lt = (a < b);
    boolean gt = (a > b);
    boolean le = (a <= b);
    boolean ge = (a >= b);

    // 逻辑运算符
    boolean t = true;
    boolean f = false;
    boolean and = t && f;
    boolean or = t || f;
    boolean not = !t;

    // 位运算符
    int m = 5;
    int n = 3;
    int band = m & n;
    int bor = m | n;
    int bxor = m ^ n;
    int bnot = ~m;
    int lshift = m << 2;
    int rshift = m >> 2;

    // 三元运算符
    int max = (a > b) ? a : b;

    println("Operators test passed");
    return 0;
}
