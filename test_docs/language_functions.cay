class Functions {
    // 静态方法模拟顶层函数
    public static int add(int a, int b) {
        return a + b;
    }

    public static void greet(String name) {
        println("Hello, " + name);
    }

    public static int max(int a, int b, int c) {
        int m = a;
        if (b > m) m = b;
        if (c > m) m = c;
        return m;
    }

    // 递归函数
    public static int factorial(int n) {
        if (n <= 1) return 1;
        return n * factorial(n - 1);
    }
}

public int main() {
    println("add(1, 2) = " + Functions.add(1, 2));
    Functions.greet("Cavvy");
    println("max(1, 2, 3) = " + Functions.max(1, 2, 3));
    // 可变参数暂不支持，使用固定参数替代
    println("sum(1, 2, 3) = " + (1 + 2 + 3));
    println("factorial(5) = " + Functions.factorial(5));

    return 0;
}
