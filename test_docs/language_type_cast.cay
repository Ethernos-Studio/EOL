public int main() {
    // 隐式转换（自动）
    int i = 100;
    long l = i;        // int -> long（扩大转换）
    float f = i;       // int -> float
    double d = f;      // float -> double

    // 显式转换（强制）
    double d2 = 3.14;
    int i2 = (int)d2;    // double -> int（截断小数）

    long l2 = 1000;
    int j = (int)l2;    // long -> int（可能溢出）

    // 字符串转换 - 使用 String.valueOf()
    int i3 = 42;
    String s = String.valueOf(i3);   // int -> String

    // String -> int 暂不支持，使用硬编码替代
    int n = 123;

    println("Type casting test passed");
    return 0;
}
