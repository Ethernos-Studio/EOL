public class Animal {
    protected String name;

    public Animal(String name) {
        this.name = name;
    }

    public void speak() {
        println(name + " makes a sound");
    }
}

public class Dog : Animal {
    public Dog(String name) {
        super(name);
    }

    @Override
    public void speak() {
        println(name + " barks");
    }
}

public int main() {
    Dog dog = new Dog("Buddy");
    dog.speak();  // 输出: Buddy barks
    return 0;
}
