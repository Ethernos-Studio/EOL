// language-guide.md OOP相关代码片段

public class Person {
    // 字段
    private String name;
    private int age;
    
    // 静态字段
    private static int count = 0;
    
    // 构造函数
    public Person(String name, int age) {
        this.name = name;
        this.age = age;
        count++;
    }
    
    // 方法
    public void greet() {
        println("Hello, I'm " + name);
    }
    
    // Getter
    public String getName() {
        return name;
    }
    
    public int getAge() {
        return age;
    }
    
    // Setter
    public void setAge(int age) {
        this.age = age;
    }
    
    // 静态方法
    public static int getCount() {
        return count;
    }
}

// 继承
public class Student : Person {
    private String school;
    
    public Student(String name, int age, String school) {
        super(name, age);
        this.school = school;
    }
    
    @Override
    public void greet() {
        println("Hello, I'm " + getName() + " from " + school);
    }
}

public int main() {
    // 创建对象
    Person p1 = new Person("Alice", 25);
    Person p2 = new Person("Bob", 30);
    
    // 调用方法
    p1.greet();
    p2.greet();
    
    // 使用Getter/Setter
    println(p1.getName() + " is " + p1.getAge() + " years old");
    p1.setAge(26);
    println(p1.getName() + " is now " + p1.getAge() + " years old");
    
    // 静态字段
    println("Total persons: " + Person.getCount());
    
    // 继承
    Student s = new Student("Charlie", 20, "MIT");
    s.greet();
    
    return 0;
}
