extern long malloc(int size);
extern void free(long ptr);
extern void memcpy(long dest, long src, int n);
extern void memset(long ptr, int value, int n);
extern int memcmp(long ptr1, long ptr2, int n);
extern void __cay_write_int(long ptr, int value);
extern int __cay_read_int(long ptr);

public int main() {
    // 分配内存
    long buffer = malloc(256);

    // 初始化内存
    memset(buffer, 0, 256);

    // 写入数据 (只需要2个参数: 指针和值)
    __cay_write_int(buffer, 42);

    // 读取数据 (只需要1个参数: 指针)
    int val = __cay_read_int(buffer);
    println("buffer[0] = " + val);

    // 释放内存
    free(buffer);

    println("Memory test passed");
    return 0;
}
