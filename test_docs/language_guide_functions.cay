// language-guide.md 函数相关代码片段

public class MathUtils {
    public static int add(int a, int b) {
        return a + b;
    }
    
    public static void greet(String name) {
        println("Hello, " + name);
    }
    
    public static int max(int a, int b, int c) {
        int m = a;
        if (b > m) m = b;
        if (c > m) m = c;
        return m;
    }
    
    // 递归函数
    public static int factorial(int n) {
        if (n <= 1) return 1;
        return n * factorial(n - 1);
    }
    
    public static int fibonacci(int n) {
        if (n <= 1) return n;
        return fibonacci(n - 1) + fibonacci(n - 2);
    }
}

public class Calculator {
    // 无参数
    public int add() {
        return 0;
    }
    
    // 一个参数
    public int add(int a) {
        return a;
    }
    
    // 两个参数
    public int add(int a, int b) {
        return a + b;
    }
    
    // 不同类型
    public double add(double a, double b) {
        return a + b;
    }
    
    // 方法重载
    public int sum(int a, int b) {
        return a + b;
    }
    
    public int sum(int a, int b, int c) {
        return a + b + c;
    }
}

public int main() {
    // 测试静态方法
    MathUtils.greet("Cavvy");
    println("10 + 20 = " + MathUtils.add(10, 20));
    println("max(5, 10, 3) = " + MathUtils.max(5, 10, 3));
    println("factorial(5) = " + MathUtils.factorial(5));
    println("fibonacci(10) = " + MathUtils.fibonacci(10));
    
    // 测试方法重载
    Calculator calc = new Calculator();
    println("add() = " + calc.add());
    println("add(5) = " + calc.add(5));
    println("add(5, 3) = " + calc.add(5, 3));
    println("add(5.5, 3.3) = " + calc.add(5.5, 3.3));
    println("sum(1, 2) = " + calc.sum(1, 2));
    println("sum(1, 2, 3) = " + calc.sum(1, 2, 3));
    
    return 0;
}
