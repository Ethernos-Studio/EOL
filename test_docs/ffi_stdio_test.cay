// ffi-guide.md 代码块7: 标准IO
// 注意：scanf 已由运行时库提供

extern long fopen(String filename, String mode);
extern int fclose(long stream);
extern int fprintf(long stream, String fmt, ...);
extern int fscanf(long stream, String fmt, ...);
extern int sprintf(long str, String fmt, ...);
extern int sscanf(String str, String fmt, ...);

public int main() {
    // printf - 由运行时提供，使用 println 替代
    println("Hello from printf!");
    
    // sprintf
    long buffer = malloc(100);
    sprintf(buffer, "Number: %d", 42);
    println("sprintf completed");
    
    // file operations
    long file = fopen("test.txt", "w");
    if (file != 0) {
        fprintf(file, "Hello, File!\n");
        fclose(file);
        println("File written");
    }
    
    free(buffer);
    return 0;
}

extern long malloc(int size);
extern void free(long ptr);
