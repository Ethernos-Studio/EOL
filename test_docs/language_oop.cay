public class Person {
    private String name;
    private int age;
    private static int count = 0;

    public Person(String name, int age) {
        this.name = name;
        this.age = age;
        count++;
    }

    public Person() {
        this("Unknown", 0);
    }

    public void introduce() {
        println("I'm " + name + ", " + age + " years old.");
    }

    public String getName() {
        return name;
    }

    public void setName(String name) {
        this.name = name;
    }

    public static int getCount() {
        return count;
    }
}

// 抽象类
public abstract class Shape {
    protected String color;

    public Shape(String color) {
        this.color = color;
    }

    public abstract double getArea();

    public void printColor() {
        println("Color: " + color);
    }
}

public class Circle : Shape {
    private double radius;

    public Circle(String color, double radius) {
        super(color);
        this.radius = radius;
    }

    public double getArea() {
        return 3.14159 * radius * radius;
    }
}

public class Rectangle : Shape {
    private double width;
    private double height;

    public Rectangle(String color, double width, double height) {
        super(color);
        this.width = width;
        this.height = height;
    }

    public double getArea() {
        return width * height;
    }
}

public int main() {
    Person p1 = new Person("Alice", 25);
    Person p2 = new Person("Bob", 30);
    p1.introduce();
    p2.introduce();

    println("Total persons: " + Person.getCount());

    Circle circle = new Circle("Red", 5.0);
    Rectangle rect = new Rectangle("Blue", 4.0, 6.0);

    println("Circle area: " + circle.getArea());
    println("Rectangle area: " + rect.getArea());

    println("OOP test passed");
    return 0;
}
