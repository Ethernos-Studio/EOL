public int main() {
    // if-else
    int score = 85;
    if (score >= 90) {
        println("A");
    } else if (score >= 80) {
        println("B");
    } else if (score >= 70) {
        println("C");
    } else {
        println("D");
    }

    // switch
    int day = 3;
    switch (day) {
        case 1:
            println("Monday");
            break;
        case 2:
            println("Tuesday");
            break;
        case 3:
            println("Wednesday");
            break;
        case 4:
        case 5:
            println("Thursday or Friday");
            break;
        default:
            println("Weekend");
            break;
    }

    // for 循环
    for (int i = 0; i < 5; i++) {
        println("for: " + i);
    }

    // while 循环
    int count = 0;
    while (count < 3) {
        println("while: " + count);
        count++;
    }

    // do-while 循环
    int num = 0;
    do {
        println("do-while: " + num);
        num++;
    } while (num < 3);

    // break 和 continue
    for (int i = 0; i < 10; i++) {
        if (i == 3) continue;
        if (i == 7) break;
        println("i = " + i);
    }

    println("Control flow test passed");
    return 0;
}
