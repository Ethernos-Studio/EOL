// syntax-reference.md 代码片段整合测试

public int main() {
    // ========== 代码块5-11: 类型声明 ==========
    // 基本类型
    boolean flag = true;
    char c = 'A';
    // byte 和 short 类型暂不支持直接赋值，使用 int 替代
    int b = 100;
    int s = 1000;
    int i = 10000;
    long l = 100000L;
    float f = 3.14f;
    double d = 3.14159;
    String str = "Hello";
    
    // 类类型
    Object obj = null;
    
    // 数组类型
    int[] arr = new int[10];
    int[][] matrix = new int[3][3];
    
    println("Types declared successfully");
    
    // ========== 代码块20-21: 语句 ==========
    // 表达式语句
    int x = 10;
    x = 20;
    x++;
    
    // if 语句
    if (x > 10) {
        println("x > 10");
    }
    
    // switch 语句
    int day = 1;
    switch (day) {
        case 1:
            println("Monday");
            break;
        default:
            println("Other");
            break;
    }
    
    // for 循环
    for (int j = 0; j < 3; j++) {
        println("j = " + j);
    }
    
    // while 循环
    int count = 0;
    while (count < 3) {
        println("count = " + count);
        count++;
    }
    
    // do-while
    int num = 0;
    do {
        println("num = " + num);
        num++;
    } while (num < 3);
    
    // break 和 continue
    for (int k = 0; k < 10; k++) {
        if (k == 2) continue;
        if (k == 5) break;
        println("k = " + k);
    }
    
    // return - 调用 TestClass 的静态方法
    println("Before return");
    TestClass.testReturn();
    
    // ========== 代码块32-37: 表达式 ==========
    // 字面量
    int lit1 = 42;
    double lit2 = 3.14;
    String lit3 = "hello";
    boolean lit4 = true;
    
    // 二元运算
    int sum = 10 + 20;
    int diff = 20 - 10;
    int prod = 10 * 20;
    int quot = 20 / 10;
    int rem = 20 % 10;
    
    // 比较
    boolean eq = (10 == 10);
    boolean ne = (10 != 20);
    boolean lt = (10 < 20);
    boolean le = (10 <= 10);
    boolean gt = (20 > 10);
    boolean ge = (10 >= 10);
    
    // 逻辑运算
    boolean and = true && false;
    boolean or = true || false;
    boolean not = !true;
    
    // 位运算
    int band = 5 & 3;
    int bor = 5 | 3;
    int bxor = 5 ^ 3;
    int bnot = ~5;
    int lshift = 5 << 1;
    int rshift = 5 >> 1;
    
    // 三元运算符
    int max = (10 > 20) ? 10 : 20;
    
    // 自增自减
    int a = 5;
    int b2 = ++a;
    int c2 = a++;
    
    // 类型转换
    double d2 = 3.14;
    int i2 = (int)d2;
    
    // 数组创建
    int[] arr2 = new int[5];
    int[] arr3 = {1, 2, 3, 4, 5};
    
    println("Expressions completed");
    
    // ========== 代码块38-43: 成员访问 ==========
    // 实例方法调用
    TestClass tc = new TestClass();
    tc.method();
    
    // 字段访问
    tc.field = 10;
    println("Field = " + tc.field);
    
    // 数组访问
    int[] arr4 = {10, 20, 30};
    println("arr4[0] = " + arr4[0]);
    
    // 赋值
    int myVar = 10;
    myVar = 20;
    
    println("All syntax tests passed!");
    return 0;
}

// testReturn 已移到 TestClass 中作为静态方法

public class TestClass {
    public static void testReturn() {
        return;
    }
    
    public int field;
    
    public void method() {
        println("Method called");
    }
}
