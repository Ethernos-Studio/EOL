// 顶层函数 - 不需要在类中定义
int add(int a, int b) {
    return a + b;
}

String greet(String name) {
    return "Hello, " + name;
}

class Main {
    public static int main(String[] args) {
        // 调用顶层函数
        int result = add(3, 5);
        println("3 + 5 = " + result);

        String message = greet("Cavvy");
        println(message);

        return 0;
    }
}
