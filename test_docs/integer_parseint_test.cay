class Main {
    public static int main(String[] args) {
        // 测试 Integer.parseInt()
        String numStr = "12345";
        int num = Integer.parseInt(numStr);
        println("Parsed: " + num);

        // 测试负数
        String negStr = "-9876";
        int neg = Integer.parseInt(negStr);
        println("Negative: " + neg);

        // 测试零
        String zeroStr = "0";
        int zero = Integer.parseInt(zeroStr);
        println("Zero: " + zero);

        return 0;
    }
}
