extern int puts(String s);
extern double sqrt(double x);
extern long time(long ptr);

public int main() {
    // 调用 C 函数
    puts("Hello, World!");

    // 使用数学函数
    double result = sqrt(2.0);
    println("sqrt(2.0) = " + result);

    // 获取系统时间
    long now = time(0);
    println("Current time: " + now);

    return 0;
}
