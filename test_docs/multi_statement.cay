public int main() {
    // 一行内多个语句
    int a = 10; int b = 20; int c = a + b;
    println("a = " + a + ", b = " + b + ", c = " + c);
    
    // 混合表达式和变量声明
    int x = 5; x = x * 2; println("x = " + x);
    
    // for 循环内的一行多语句
    for (int i = 0; i < 3; i++) { int j = i * 2; println("i=" + i + ", j=" + j); }
    
    println("Multi-statement test passed");
    return 0;
}
