public class Person {
    private String name;
    private int age;

    // 构造函数
    public Person(String name, int age) {
        this.name = name;
        this.age = age;
    }

    // 方法
    public void greet() {
        println("Hello, I'm " + name + ", " + age + " years old.");
    }

    // Getter
    public String getName() {
        return name;
    }
}

public int main() {
    Person person = new Person("Alice", 25);
    person.greet();
    println("Name: " + person.getName());
    return 0;
}
