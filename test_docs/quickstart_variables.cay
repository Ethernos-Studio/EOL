public int main() {
    // 传统方式
    int x = 10;
    String name = "Cavvy";

    // 现代方式（0.4.3+）
    var y: int = 20;           // var: 可变变量
    let greeting: String = "Hi"; // let: 可变变量（与 var 相同）

    // 自动类型推断
    auto count = 100;          // 推断为 int
    auto pi = 3.14159;         // 推断为 double
    auto message = "Hello";    // 推断为 String

    // 不可变变量
    final int MAX_SIZE = 100;
    final var MIN_VALUE: int = 0;

    println("x = " + x);
    return 0;
}
