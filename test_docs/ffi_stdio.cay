extern long fopen(String filename, String mode);
extern int fclose(long stream);
extern int fprintf(long stream, String fmt, ...);
extern int fgetc(long stream);
extern long malloc(int size);
extern void free(long ptr);

public int main() {
    // 写入文件
    long file = fopen("test_docs/test_file.txt", "w");
    fprintf(file, "Hello, World!\n");
    fclose(file);

    // 读取文件 - 使用 fgetc 逐字符读取
    file = fopen("test_docs/test_file.txt", "r");
    long buffer = malloc(256);
    int i = 0;
    int c;
    while ((c = fgetc(file)) != -1 && i < 255) {
        // 使用指针运算写入字节
        long addr = buffer + i;
        __cay_write_int(addr, c);  // 写入整数值（低字节有效）
        i = i + 1;
    }
    // 写入 null terminator
    __cay_write_int(buffer + i, 0);
    String content = __cay_ptr_to_string(buffer);
    println("File content: " + content);
    free(buffer);
    fclose(file);

    println("File I/O test passed");
    return 0;
}
