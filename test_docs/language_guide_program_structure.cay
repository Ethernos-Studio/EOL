// language-guide.md 代码块4: 程序结构
// 注意：printf 已由运行时库提供

// 预处理器指令
#define DEBUG

// 类定义 - 将顶层函数改为静态方法
public class Helper {
    public static void helper() {
        println("Helper function called");
    }
}

// 类定义
public class MyClass {
    // 字段
    private int value;
    
    // 构造函数
    public MyClass(int v) {
        this.value = v;
    }
    
    // 方法
    public int getValue() {
        return value;
    }
}

// 程序入口
public int main() {
    MyClass obj = new MyClass(42);
    println(obj.getValue());
    Helper.helper();
    return 0;
}
