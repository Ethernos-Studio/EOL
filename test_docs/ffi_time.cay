extern long time(long ptr);
extern long clock();

#define CLOCKS_PER_SEC 1000

public int main() {
    // 获取当前时间
    long now = time(0);
    println("Current time: " + now);

    // 测量代码执行时间
    long start = clock();

    // 执行一些操作...
    for (int i = 0; i < 1000000; i++) {
        // 空循环
    }

    long end = clock();
    long elapsed = (end - start) / CLOCKS_PER_SEC;
    println("Elapsed: " + elapsed + " seconds");

    println("Time test passed");
    return 0;
}
