// quickstart.md 中的代码片段整合测试
// 包含变量声明、控制流、数组、类和继承的代码片段

public int main() {
    // ========== 代码块4: 变量声明 ==========
    // 传统方式
    int x = 10;
    String name = "Cavvy";
    
    // 现代方式
    var y = 20;
    let greeting = "Hi";
    
    // 自动类型推断
    auto count = 100;
    auto pi = 3.14159;
    auto message = "Hello";
    
    // 不可变变量
    final int MAX_SIZE = 100;
    final int MIN_VALUE = 0;
    
    println("x = " + x);
    
    // ========== 代码块5: 控制流 ==========
    // if-else
    int score = 85;
    if (score >= 90) {
        println("A");
    } else if (score >= 80) {
        println("B");
    } else {
        println("C");
    }
    
    // for 循环
    for (int i = 0; i < 5; i++) {
        println("Iteration: " + i);
    }
    
    // while 循环
    int count2 = 0;
    while (count2 < 3) {
        println("Count: " + count2);
        count2++;
    }
    
    // do-while 循环
    int num = 0;
    do {
        println("Number: " + num);
        num++;
    } while (num < 3);
    
    // switch 语句
    int day = 3;
    switch (day) {
        case 1:
            println("Monday");
            break;
        case 2:
            println("Tuesday");
            break;
        case 3:
            println("Wednesday");
            break;
        default:
            println("Other day");
            break;
    }
    
    // ========== 代码块6: 数组 ==========
    // 一维数组
    int[] numbers = new int[5];
    numbers[0] = 10;
    numbers[1] = 20;
    
    // 数组初始化
    int[] values = {1, 2, 3, 4, 5};
    
    // 多维数组
    int[][] matrix = new int[3][3];
    matrix[0][0] = 1;
    matrix[1][1] = 2;
    matrix[2][2] = 3;
    
    // 数组长度
    println("Array length: " + values.length);
    
    // 遍历数组
    for (int i = 0; i < values.length; i++) {
        println("values[" + i + "] = " + values[i]);
    }
    
    return 0;
}
