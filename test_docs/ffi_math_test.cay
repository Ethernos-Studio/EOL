// ffi-guide.md 数学函数测试

extern double sqrt(double x);
extern double pow(double x, double y);
extern double sin(double x);
extern double cos(double x);
extern double tan(double x);
extern double log(double x);
extern double exp(double x);
extern double fabs(double x);
extern double ceil(double x);
extern double floor(double x);
extern double fmod(double x, double y);

public int main() {
    // sqrt
    double r1 = sqrt(16.0);
    println("sqrt(16) = " + r1);
    
    // pow
    double r2 = pow(2.0, 10.0);
    println("pow(2, 10) = " + r2);
    
    // trigonometric
    double r3 = sin(3.14159 / 2);
    println("sin(pi/2) = " + r3);
    
    double r4 = cos(0.0);
    println("cos(0) = " + r4);
    
    // log and exp
    double r5 = log(2.71828);
    println("log(e) = " + r5);
    
    double r6 = exp(1.0);
    println("exp(1) = " + r6);
    
    // fabs, ceil, floor
    double r7 = fabs(-5.5);
    println("fabs(-5.5) = " + r7);
    
    double r8 = ceil(3.2);
    println("ceil(3.2) = " + r8);
    
    double r9 = floor(3.8);
    println("floor(3.8) = " + r9);
    
    // fmod
    double r10 = fmod(10.5, 3.0);
    println("fmod(10.5, 3) = " + r10);
    
    return 0;
}
