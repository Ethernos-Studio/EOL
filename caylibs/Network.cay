/**
 * Network.cay - 网络库
 * 
 * 提供TCP/UDP socket、HTTP客户端、DNS解析等功能
 * 版本: 0.5.1.0
 */

/* ============================================================================
 * 平台特定的C库函数声明
 * ============================================================================ */

/* Windows平台使用ws2_32库 */
#ifdef _WIN32
extern {
    /* WSA (Windows Sockets API) 函数 */
    c_short WSAStartup(c_short wVersionRequired, long lpWSAData);
    int WSACleanup();
    int WSAGetLastError();
    
    /* Socket函数 */
    long socket(int af, int type, int protocol);
    int closesocket(long s);
    int bind(long s, long name, int namelen);
    int listen(long s, int backlog);
    long accept(long s, long addr, int addrlen);
    int connect(long s, long name, int namelen);
    int send(long s, long buf, int len, int flags);
    int recv(long s, long buf, int len, int flags);
    int sendto(long s, long buf, int len, int flags, long to, int tolen);
    int recvfrom(long s, long buf, int len, int flags, long from, long fromlen);
    int shutdown(long s, int how);
    
    /* 地址转换 */
    long inet_addr(long cp);
    long inet_ntoa(long in);
    
    /* 主机信息 */
    long gethostbyname(long name);
    long gethostbyaddr(long addr, int len, int type);
    
    /* IO控制 */
    int ioctlsocket(long s, long cmd, long argp);
    int setsockopt(long s, int level, int optname, long optval, int optlen);
    int getsockopt(long s, int level, int optname, long optval, long optlen);
    
    /* 内存分配 */
    long malloc(int size);
    void free(long ptr);
}
#else
/* Linux/Unix平台 */
extern {
    /* Socket函数 */
    int socket(int domain, int type, int protocol);
    int close(int fd);
    int bind(int sockfd, long addr, int addrlen);
    int listen(int sockfd, int backlog);
    int accept(int sockfd, long addr, int addrlen);
    int connect(int sockfd, long addr, int addrlen);
    long send(int sockfd, long buf, long len, int flags);
    long recv(int sockfd, long buf, long len, int flags);
    long sendto(int sockfd, long buf, long len, int flags, long dest_addr, int addrlen);
    long recvfrom(int sockfd, long buf, long len, int flags, long src_addr, long addrlen);
    int shutdown(int sockfd, int how);

    /* 地址转换 */
    int inet_pton(int af, long src, long dst);
    long inet_ntop(int af, long src, long dst, int size);
    int inet_aton(long cp, long inp);
    long inet_addr(long cp);
    long inet_ntoa(long in);

    /* 主机信息 */
    long gethostbyname(long name);
    long gethostbyaddr(long addr, int len, int type);
    void herror(long s);

    /* IO控制 */
    int fcntl(int fd, int cmd, int arg);
    int setsockopt(int sockfd, int level, int optname, long optval, int optlen);
    int getsockopt(int sockfd, int level, int optname, long optval, long optlen);
    int select(int nfds, long readfds, long writefds, long exceptfds, long timeout);

    /* 内存分配 */
    long malloc(int size);
    void free(long ptr);
}
#endif

/* ============================================================================
 * 常量定义
 * ============================================================================ */

/* 地址族 */
#define AF_UNSPEC 0
#define AF_INET 2
#define AF_INET6 23

/* Socket类型 */
#define SOCK_STREAM 1
#define SOCK_DGRAM 2
#define SOCK_RAW 3

/* Socket选项级别 */
#define SOL_SOCKET 0xFFFF

/* Socket选项 */
#define SO_REUSEADDR 0x0004
#define SO_BROADCAST 0x0020
#define SO_SNDBUF 0x1001
#define SO_RCVBUF 0x1002

/* 协议 */
#define IPPROTO_TCP 6
#define IPPROTO_UDP 17

/* TCP选项 */
#define TCP_NODELAY 0x0001

/* 无效socket */
#ifdef _WIN32
#define INVALID_SOCKET -1
#else
#define INVALID_SOCKET -1
#endif

/* shutdown 选项 */
#define SD_RECEIVE 0
#define SD_SEND 1
#define SD_BOTH 2

/* ============================================================================
 * SocketAddr类 - 表示网络地址
 * ============================================================================ */

public class SocketAddr {
    /* 地址结构体 (sockaddr_in)
     * struct sockaddr_in {
     *     short sin_family;      // 2 bytes, offset 0
     *     ushort sin_port;       // 2 bytes, offset 2
     *     in_addr sin_addr;      // 4 bytes, offset 4
     *     char sin_zero[8];      // 8 bytes, offset 8
     * };
     * 总计: 16 bytes
     */
    
    /* 使用4个int来存储16字节的sockaddr_in结构 */
    public int word0;  /* family + port */
    public int word1;  /* addr */
    public int word2;  /* zero[0-3] */
    public int word3;  /* zero[4-7] */
    
    public SocketAddr() {
        this.word0 = 0;
        this.word1 = 0;
        this.word2 = 0;
        this.word3 = 0;
    }
    
    /**
     * 创建IPv4地址
     * @param ip IP地址字符串 (如 "127.0.0.1")
     * @param port 端口号
     */
    public SocketAddr fromString(String ip, int port) {
        SocketAddr addr = new SocketAddr();
        
        /* 解析IP地址 */
        long ipPtr = ip.c_str();
        long ipAddr = inet_addr(ipPtr);
        
        /* 构建sockaddr_in结构 */
        int family = AF_INET;
        int portNetwork = NetworkUtils.htons(port);
        
        /* word0 = (port << 16) | family */
        addr.word0 = (portNetwork << 16) | (family & 0xFFFF);
        addr.word1 = (int)ipAddr;
        addr.word2 = 0;
        addr.word3 = 0;
        
        return addr;
    }
    
    /**
     * 从IP和端口创建地址（fromString的别名）
     * @param ip IP地址字符串
     * @param port 端口号
     */
    public SocketAddr fromIpPort(String ip, int port) {
        return this.fromString(ip, port);
    }
    
    /**
     * 创建本地地址 (127.0.0.1:port)
     * @param port 端口号
     */
    public SocketAddr localhost(int port) {
        return this.fromString("127.0.0.1", port);
    }
    
    /**
     * 创建通配地址 (0.0.0.0:port)
     * @param port 端口号
     */
    public SocketAddr any(int port) {
        SocketAddr addr = new SocketAddr();
        
        int family = AF_INET;
        int portNetwork = NetworkUtils.htons(port);
        int ipAddr = 0;  /* INADDR_ANY = 0 */
        
        addr.word0 = (portNetwork << 16) | (family & 0xFFFF);
        addr.word1 = ipAddr;
        addr.word2 = 0;
        addr.word3 = 0;
        
        return addr;
    }
    
    /**
     * 获取端口号
     */
    public int getPort() {
        int portNetwork = (this.word0 >> 16) & 0xFFFF;
        return NetworkUtils.ntohs(portNetwork);
    }
    
    /**
     * 获取IP地址字符串
     */
    public String getIp() {
        /* 从word1中提取IP地址 */
        int ipAddr = this.word1;
        
        /* 手动转换为字符串格式 */
        int b0 = (ipAddr >> 0) & 0xFF;
        int b1 = (ipAddr >> 8) & 0xFF;
        int b2 = (ipAddr >> 16) & 0xFF;
        int b3 = (ipAddr >> 24) & 0xFF;
        
        /* 构建IP字符串 */
        String result = "";
        result = result + (String)b3 + "." + (String)b2 + "." + (String)b1 + "." + (String)b0;
        return result;
    }
}

/* ============================================================================
 * NetworkUtils类 - 网络工具函数
 * ============================================================================ */

public class NetworkUtils {
    private static bool initialized = false;
    
    /**
     * 初始化网络库
     * @return true如果成功
     */
    public static bool init() {
        if (initialized) {
            return true;
        }
        
        #ifdef _WIN32
        /* Windows需要初始化Winsock */
        c_short version = 0x0202;  /* Winsock 2.2 */
        long wsadata = malloc(400);  /* WSAData结构约400字节 */
        if (wsadata == 0) {
            return false;
        }
        
        c_short result = WSAStartup(version, wsadata);
        free(wsadata);
        
        if (result != 0) {
            return false;
        }
        #endif
        
        initialized = true;
        return true;
    }
    
    /**
     * 清理网络库
     */
    public static void cleanup() {
        if (!initialized) {
            return;
        }
        
        #ifdef _WIN32
        WSACleanup();
        #endif
        
        initialized = false;
    }
    
    /**
     * 获取最后错误码
     */
    public static int getLastError() {
        #ifdef _WIN32
        return WSAGetLastError();
        #else
        return 0;  /* Linux使用errno，需要额外处理 */
        #endif
    }
    
    /**
     * 主机字节序转网络字节序 (16位)
     */
    public static int htons(int hostshort) {
        /* 简单的字节交换 */
        return ((hostshort >> 8) & 0xFF) | ((hostshort << 8) & 0xFF00);
    }
    
    /**
     * 主机字节序转网络字节序 (32位)
     */
    public static int htonl(int hostlong) {
        return (int)(((hostlong >> 24) & 0xFF) |
               ((hostlong >> 8) & 0xFF00) |
               ((hostlong << 8) & 0xFF0000) |
               ((hostlong << 24) & 0xFF000000));
    }
    
    /**
     * 网络字节序转主机字节序 (16位)
     */
    public static int ntohs(int netshort) {
        return htons(netshort);  /* 相同的操作 */
    }
    
    /**
     * 网络字节序转主机字节序 (32位)
     */
    public static int ntohl(int netlong) {
        return htonl(netlong);  /* 相同的操作 */
    }
    
    /**
     * 获取主机名对应的IP地址
     * @param hostname 主机名
     * @return IP地址字符串
     */
    public static String resolveHost(String hostname) {
        long hostent = gethostbyname(hostname.c_str());
        if (hostent == 0) {
            return "";
        }
        /* hostent结构: h_name(8), h_aliases(8), h_addrtype(4), h_length(4), h_addr_list(8) */
        long addr_list = __cay_read_ptr(hostent + 24);
        if (addr_list == 0) {
            return "";
        }
        long addr = __cay_read_ptr(addr_list);
        if (addr == 0) {
            return "";
        }
        return __cay_ptr_to_string(inet_ntoa(addr));
    }
    
    /**
     * 获取主机名对应的IP地址（内部实现，使用C字符串）
     * @param hostnamePtr 主机名C字符串指针
     * @return IP地址字符串
     */
    private static String resolveHostInternal(long hostnamePtr) {
        long hostent = gethostbyname(hostnamePtr);
        if (hostent == 0) {
            return "";
        }
        long addr_list = __cay_read_ptr(hostent + 24);
        if (addr_list == 0) {
            return "";
        }
        long addr = __cay_read_ptr(addr_list);
        if (addr == 0) {
            return "";
        }
        return __cay_ptr_to_string(inet_ntoa(addr));
    }
    
    /**
     * 创建TCP客户端并连接到服务器
     * @param ip 服务器IP
     * @param port 服务器端口
     * @return 连接的TcpSocket，null表示失败
     */
    public static TcpSocket connectTcp(String ip, int port) {
        if (!NetworkUtils.init()) {
            return null;
        }
        
        TcpSocket socket = new TcpSocket();
        if (!socket.connectTo(ip, port)) {
            socket.close();
            return null;
        }
        
        return socket;
    }
    
    /**
     * 创建UDP socket
     * @return UdpSocket，null表示失败
     */
    public static UdpSocket createUdp() {
        if (!NetworkUtils.init()) {
            return null;
        }
        
        return new UdpSocket();
    }
    
    /**
     * 创建TCP服务器
     * @param port 监听端口
     * @return TcpServer，null表示失败
     */
    public static TcpServer createTcpServer(int port) {
        if (!NetworkUtils.init()) {
            return null;
        }
        
        TcpServer server = new TcpServer();
        if (!server.bindTo(port)) {
            server.close();
            return null;
        }
        
        if (!server.listen(5)) {
            server.close();
            return null;
        }
        
        return server;
    }
}

/* ============================================================================
 * TcpSocket类 - TCP客户端Socket
 * ============================================================================ */

public class TcpSocket {
    int handle;
    bool connected;
    
    public TcpSocket() {
        /* 创建socket */
        #ifdef _WIN32
        this.handle = socket(AF_INET, SOCK_STREAM, IPPROTO_TCP);
        #else
        this.handle = socket(AF_INET, SOCK_STREAM, IPPROTO_TCP);
        #endif
        this.connected = false;
    }
    
    /**
     * 包级私有构造函数，用于TcpServer.accept()
     */
    TcpSocket(long handle, bool connected) {
        this.handle = handle;
        this.connected = connected;
    }
    
    /**
     * 创建socket并连接到服务器
     * @param ip 服务器IP
     * @param port 服务器端口
     * @return true如果成功
     */
    public bool connectTo(String ip, int port) {
        /* 创建socket */
        #ifdef _WIN32
        this.handle = socket(AF_INET, SOCK_STREAM, IPPROTO_TCP);
        #else
        this.handle = socket(AF_INET, SOCK_STREAM, IPPROTO_TCP);
        #endif
        
        if (this.handle == INVALID_SOCKET) {
            return false;
        }
        
        /* 构建地址 */
        SocketAddr addr = new SocketAddr().fromString(ip, port);
        
        /* 连接 */
        int result = connect(this.handle, (long)(&addr), 16);
        if (result != 0) {
            this.close();
            return false;
        }
        
        this.connected = true;
        return true;
    }
    
    /**
     * 发送数据
     * @param data 要发送的数据
     * @return 发送的字节数，-1表示失败
     */
    public int send(String data) {
        if (!this.connected || this.handle == INVALID_SOCKET) {
            return -1;
        }
        
        long buf = data.c_str();
        int len = data.length();
        
        #ifdef _WIN32
        int result = send(this.handle, buf, len, 0);
        #else
        int result = (int)send(this.handle, buf, len, 0);
        #endif
        
        return result;
    }
    
    /**
     * 接收数据
     * @param maxLen 最大接收字节数
     * @return 接收到的数据，null表示失败或连接关闭
     */
    public String receive(int maxLen) {
        if (!this.connected || this.handle == INVALID_SOCKET) {
            return null;
        }
        
        long buf = malloc(maxLen);
        if (buf == 0) {
            return null;
        }
        
        #ifdef _WIN32
        int received = recv(this.handle, buf, maxLen, 0);
        #else
        int received = (int)recv(this.handle, buf, maxLen, 0);
        #endif
        
        if (received <= 0) {
            free(buf);
            return null;
        }
        
        /* 转换为String */
        String result = __cay_ptr_to_string(buf);
        free(buf);
        
        return result;
    }
    
    /**
     * 接收数据（receive的别名）
     * @param maxLen 最大接收字节数
     * @return 接收到的数据，null表示失败或连接关闭
     */
    public String receiveString(int maxLen) {
        return this.receive(maxLen);
    }
    
    /**
     * 关闭socket
     */
    public void close() {
        if (this.handle != INVALID_SOCKET) {
            #ifdef _WIN32
            shutdown(this.handle, 2);  /* SD_BOTH */
            closesocket(this.handle);
            #else
            shutdown(this.handle, 2);  /* SHUT_RDWR */
            close(this.handle);
            #endif
            this.handle = INVALID_SOCKET;
        }
        this.connected = false;
    }
    
    /**
     * 关闭写入端（shutdown write）
     */
    public bool shutdownWrite() {
        if (this.handle == INVALID_SOCKET) {
            return false;
        }
        int result = shutdown(this.handle, SD_SEND);
        return result == 0;
    }
    
    /**
     * 关闭读取端（shutdown read）
     */
    public bool shutdownRead() {
        if (this.handle == INVALID_SOCKET) {
            return false;
        }
        int result = shutdown(this.handle, SD_RECEIVE);
        return result == 0;
    }
    
    /**
     * 关闭所有（shutdown both）
     */
    public bool shutdown() {
        if (this.handle == INVALID_SOCKET) {
            return false;
        }
        int result = shutdown(this.handle, SD_BOTH);
        return result == 0;
    }
    
    /**
     * 检查是否已连接
     */
    public bool isConnected() {
        return this.connected;
    }
    
    /**
     * 检查socket是否有效
     */
    public bool isValid() {
        return this.handle != INVALID_SOCKET;
    }
    
    /**
     * 设置地址重用选项
     */
    public void setReuseAddr(bool enable) {
        if (this.handle != INVALID_SOCKET) {
            int value = enable ? 1 : 0;
            setsockopt((int)this.handle, SOL_SOCKET, SO_REUSEADDR, (long)(&value), 4);
        }
    }
    
    /**
     * 设置TCP_NODELAY选项（禁用Nagle算法）
     */
    public void setTcpNoDelay(bool enable) {
        if (this.handle != INVALID_SOCKET) {
            int value = enable ? 1 : 0;
            setsockopt((int)this.handle, IPPROTO_TCP, TCP_NODELAY, (long)(&value), 4);
        }
    }
    
    /**
     * 设置发送缓冲区大小
     */
    public void setSendBufferSize(int size) {
        if (this.handle != INVALID_SOCKET) {
            setsockopt((int)this.handle, SOL_SOCKET, SO_SNDBUF, (long)(&size), 4);
        }
    }
    
    /**
     * 设置接收缓冲区大小
     */
    public void setRecvBufferSize(int size) {
        if (this.handle != INVALID_SOCKET) {
            setsockopt((int)this.handle, SOL_SOCKET, SO_RCVBUF, (long)(&size), 4);
        }
    }
}

/* ============================================================================
 * TcpServer类 - TCP服务器
 * ============================================================================ */

public class TcpServer {
    private int handle;
    private int port;
    private bool listening;
    
    public TcpServer() {
        this.handle = INVALID_SOCKET;
        this.port = 0;
        this.listening = false;
    }
    
    /**
     * 绑定到指定地址
     * @param addr 要绑定的地址
     * @return true如果成功
     */
    public bool bind(SocketAddr addr) {
        /* 创建socket */
        #ifdef _WIN32
        this.handle = socket(AF_INET, SOCK_STREAM, IPPROTO_TCP);
        #else
        this.handle = socket(AF_INET, SOCK_STREAM, IPPROTO_TCP);
        #endif
        
        if (this.handle == INVALID_SOCKET) {
            return false;
        }
        
        /* 设置地址重用 */
        int reuse = 1;
        setsockopt((int)this.handle, SOL_SOCKET, SO_REUSEADDR, (long)(&reuse), 4);
        
        /* 调用系统bind函数 */
        int sysResult = bind(this.handle, (long)(&addr), 16);
        if (sysResult == 0) {
            /* 从word0中提取端口号 (word0 = (port_network << 16) | family) */
            int portNetwork = (addr.word0 >> 16) & 0xFFFF;
            this.port = NetworkUtils.ntohs(portNetwork);
            return true;
        }
        
        this.close();
        return false;
    }
    
    /**
     * 绑定到指定端口
     * @param port 端口号
     * @return true如果成功
     */
    public bool bindTo(int port) {
        SocketAddr addr = new SocketAddr().any(port);
        bool bindResult = this.bind(addr);
        return bindResult;
    }
    
    /**
     * 开始监听
     * @param backlog 连接队列长度
     * @return true如果成功
     */
    public bool listen(int backlog) {
        if (this.handle == INVALID_SOCKET) {
            return false;
        }
        
        int result = listen(this.handle, backlog);
        if (result == 0) {
            this.listening = true;
            return true;
        }
        
        return false;
    }
    
    /**
     * 接受连接
     * @return 新的TcpSocket，null表示失败
     */
    public TcpSocket accept() {
        if (!this.listening || this.handle == INVALID_SOCKET) {
            return null;
        }
        
        int sock = this.handle;
        long ca = 0;
        int al = 16;
        
        long ch = accept(sock, ca, al);
        
        if (ch == INVALID_SOCKET) {
            return null;
        }
        
        return new TcpSocket(ch, true);
    }
    
    /**
     * 关闭服务器
     */
    public void close() {
        this.listening = false;
        if (this.handle != INVALID_SOCKET) {
            #ifdef _WIN32
            closesocket(this.handle);
            #else
            close(this.handle);
            #endif
            this.handle = INVALID_SOCKET;
        }
    }
    
    /**
     * 获取绑定的端口
     */
    public int getPort() {
        return this.port;
    }
    
    /**
     * 检查是否在监听
     */
    public bool isListening() {
        return this.listening;
    }
}

/* ============================================================================
 * UdpSocket类 - UDP Socket
 * ============================================================================ */

public class UdpSocket {
    private int handle;
    private bool bound;
    
    public UdpSocket() {
        /* 创建UDP socket */
        #ifdef _WIN32
        this.handle = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
        #else
        this.handle = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
        #endif
        this.bound = false;
    }
    
    /**
     * 绑定到指定端口
     * @param port 端口号
     * @return true如果成功
     */
    public bool bindTo(int port) {
        if (this.handle == INVALID_SOCKET) {
            return false;
        }
        
        /* 设置地址重用 */
        int reuse = 1;
        setsockopt((int)this.handle, SOL_SOCKET, SO_REUSEADDR, (long)(&reuse), 4);
        
        /* 绑定地址 */
        SocketAddr addr = new SocketAddr().any(port);
        int result = bind(this.handle, (long)(&addr), 16);
        
        if (result == 0) {
            this.bound = true;
            return true;
        }
        
        this.close();
        return false;
    }
    
    /**
     * 发送数据到指定地址
     * @param data 要发送的数据
     * @param ip 目标IP
     * @param port 目标端口
     * @return 发送的字节数，-1表示失败
     */
    public int sendTo(String data, String ip, int port) {
        if (this.handle == INVALID_SOCKET) {
            return -1;
        }
        
        SocketAddr addr = new SocketAddr().fromString(ip, port);
        long buf = data.c_str();
        int len = data.length();
        
        #ifdef _WIN32
        int result = sendto(this.handle, buf, len, 0, (long)(&addr), 16);
        #else
        int result = (int)sendto(this.handle, buf, len, 0, (long)(&addr), 16);
        #endif
        
        return result;
    }
    
    /**
     * 接收数据
     * @param maxLen 最大接收字节数
     * @param senderAddr 发送者地址（输出参数）
     * @return 接收到的数据，null表示失败
     */
    public String receiveFrom(int maxLen, SocketAddr senderAddr) {
        if (this.handle == INVALID_SOCKET) {
            return null;
        }
        
        long buf = malloc(maxLen);
        if (buf == 0) {
            return null;
        }
        
        long addrBuf = malloc(16);
        if (addrBuf == 0) {
            free(buf);
            return null;
        }
        
        long addrlen = 16;
        
        #ifdef _WIN32
        int received = recvfrom(this.handle, buf, maxLen, 0, addrBuf, (long)(&addrlen));
        #else
        int received = (int)recvfrom(this.handle, buf, maxLen, 0, addrBuf, (long)(&addrlen));
        #endif
        
        if (received <= 0) {
            free(buf);
            free(addrBuf);
            return null;
        }
        
        /* 复制发送者地址 */
        senderAddr.word0 = (int)__cay_read_ptr(addrBuf);
        senderAddr.word1 = (int)__cay_read_ptr(addrBuf + 4);
        senderAddr.word2 = (int)__cay_read_ptr(addrBuf + 8);
        senderAddr.word3 = (int)__cay_read_ptr(addrBuf + 12);
        
        /* 转换为String */
        String result = __cay_ptr_to_string(buf);
        
        free(buf);
        free(addrBuf);
        
        return result;
    }
    
    /**
     * 关闭socket
     */
    public void close() {
        this.bound = false;
        if (this.handle != INVALID_SOCKET) {
            #ifdef _WIN32
            closesocket(this.handle);
            #else
            close(this.handle);
            #endif
            this.handle = INVALID_SOCKET;
        }
    }
    
    /**
     * 检查是否已绑定
     */
    public bool isBound() {
        return this.bound;
    }
    
    /**
     * 检查socket是否有效
     */
    public bool isValid() {
        return this.handle != INVALID_SOCKET;
    }
}

/* ============================================================================
 * HttpRequest类 - HTTP请求
 * ============================================================================ */

public class HttpRequest {
    private String method;
    private String url;
    private String headers;
    private String body;
    
    public HttpRequest() {
        this.method = "GET";
        this.url = "";
        this.headers = "";
        this.body = "";
    }
    
    /**
     * 设置请求方法
     */
    public HttpRequest setMethod(String method) {
        this.method = method;
        return this;
    }
    
    /**
     * 设置URL
     */
    public HttpRequest setUrl(String url) {
        this.url = url;
        return this;
    }
    
    /**
     * 添加请求头
     */
    public HttpRequest addHeader(String key, String value) {
        this.headers = this.headers + key + ": " + value + "\r\n";
        return this;
    }
    
    /**
     * 设置请求体
     */
    public HttpRequest setBody(String body) {
        this.body = body;
        return this;
    }
    
    /**
     * 构建HTTP请求字符串
     */
    public String build() {
        String request = this.method + " " + this.url + " HTTP/1.1\r\n";
        request = request + "Host: localhost\r\n";
        request = request + "User-Agent: CavvyHTTP/0.5\r\n";
        
        if (this.body.length() > 0) {
            request = request + "Content-Length: " + (String)this.body.length() + "\r\n";
        }
        
        request = request + this.headers;
        request = request + "\r\n";
        request = request + this.body;
        
        return request;
    }
}

/* ============================================================================
 * HttpResponse类 - HTTP响应
 * ============================================================================ */

public class HttpResponse {
    private int statusCode;
    private String statusText;
    private String headers;
    private String body;
    
    public HttpResponse() {
        this.statusCode = 200;
        this.statusText = "OK";
        this.headers = "";
        this.body = "";
    }
    
    /**
     * 设置状态码
     */
    public HttpResponse setStatus(int code, String text) {
        this.statusCode = code;
        this.statusText = text;
        return this;
    }
    
    /**
     * 添加响应头
     */
    public HttpResponse addHeader(String key, String value) {
        this.headers = this.headers + key + ": " + value + "\r\n";
        return this;
    }
    
    /**
     * 设置响应体
     */
    public HttpResponse setBody(String body) {
        this.body = body;
        return this;
    }
    
    /**
     * 构建HTTP响应字符串
     */
    public String build() {
        String response = "HTTP/1.1 " + (String)this.statusCode + " " + this.statusText + "\r\n";
        response = response + "Content-Length: " + (String)this.body.length() + "\r\n";
        response = response + this.headers;
        response = response + "\r\n";
        response = response + this.body;
        
        return response;
    }
    
    /**
     * 获取状态码
     */
    public int getStatusCode() {
        return this.statusCode;
    }
    
    /**
     * 获取响应体
     */
    public String getBody() {
        return this.body;
    }
}

/* ============================================================================
 * HttpClient类 - HTTP客户端
 * ============================================================================ */

public class HttpClient {
    private String baseUrl;
    
    public HttpClient() {
        this.baseUrl = "";
    }
    
    /**
     * 设置基础URL
     */
    public HttpClient setBaseUrl(String url) {
        this.baseUrl = url;
        return this;
    }
    
    /**
     * 发送GET请求
     * @param path 请求路径
     * @return 响应字符串
     */
    public String get(String path) {
        return this.request("GET", path, "");
    }

    /**
     * 发送POST请求
     * @param path 请求路径
     * @param body 请求体
     * @return 响应字符串
     */
    public String post(String path, String body) {
        return this.request("POST", path, body);
    }

    /**
     * 发送HTTP请求并获取响应
     * @param method HTTP方法
     * @param path 请求路径
     * @param body 请求体
     * @return 响应字符串
     */
    private String request(String method, String path, String body) {
        /* 解析URL获取主机和端口 */
        String url = path;
        if (this.baseUrl.length() > 0) {
            url = this.baseUrl + path;
        }

        /* 解析URL: http://host:port/path 或 https://host:port/path */
        String host = "";
        int port = 80;
        String requestPath = "/";

        /* 移除协议前缀 */
        int protocolEnd = url.indexOf("://");
        if (protocolEnd >= 0) {
            String protocol = url.substring(0, protocolEnd);
            url = url.substring(protocolEnd + 3);
            if (protocol == "https") {
                port = 443;
            }
        }

        /* 提取路径 */
        int pathStart = url.indexOf("/");
        if (pathStart >= 0) {
            requestPath = url.substring(pathStart);
            url = url.substring(0, pathStart);
        }

        /* 提取主机和端口 */
        int portStart = url.indexOf(":");
        if (portStart >= 0) {
            host = url.substring(0, portStart);
            port = this.parseInt(url.substring(portStart + 1));
        } else {
            host = url;
        }

        /* 建立TCP连接 */
        TcpSocket socket = new TcpSocket();
        if (!socket.connectTo(host, port)) {
            return "";
        }

        /* 构建HTTP请求 */
        HttpRequest request = new HttpRequest();
        request.setMethod(method);
        request.setUrl(requestPath);
        request.addHeader("Host", host);
        request.addHeader("User-Agent", "CavvyHTTP/0.5");
        request.addHeader("Accept", "*/*");
        request.addHeader("Connection", "close");

        if (method == "POST" && body.length() > 0) {
            request.addHeader("Content-Type", "application/x-www-form-urlencoded");
            request.setBody(body);
        }

        String requestStr = request.build();

        /* 发送请求 */
        if (!socket.send(requestStr)) {
            socket.close();
            return "";
        }

        /* 接收响应 */
        String response = "";
        String chunk = "";
        int maxIterations = 1000;
        int iterations = 0;

        while (iterations < maxIterations) {
            chunk = socket.receive(4096);
            if (chunk == null || chunk.length() == 0) {
                break;
            }
            response = response + chunk;
            iterations = iterations + 1;
        }

        socket.close();

        return response;
    }

    /**
     * 解析整数
     * @param str 字符串
     * @return 整数值，解析失败返回0
     */
    private int parseInt(String str) {
        if (str == null || str.length() == 0) {
            return 0;
        }

        int result = 0;
        int sign = 1;
        int i = 0;

        /* 处理符号 */
        if (str.charAt(0) == '-') {
            sign = -1;
            i = 1;
        } else if (str.charAt(0) == '+') {
            i = 1;
        }

        while (i < str.length()) {
            char c = str.charAt(i);
            if (c >= '0' && c <= '9') {
                result = result * 10 + ((int)c - (int)'0');
            } else {
                break;
            }
            i = i + 1;
        }

        return result * sign;
    }
}

/* ============================================================================
 * WebServer类 - 简单的Web服务器
 * ============================================================================ */

public class WebServer {
    private TcpServer server;
    private int port;
    private bool running;
    
    public WebServer(int port) {
        this.port = port;
        this.running = false;
        this.server = new TcpServer();
    }
    
    /**
     * 启动服务器
     */
    public bool start() {
        /* 初始化网络 */
        bool initResult = NetworkUtils.init();
        if (!initResult) {
            println("网络初始化失败");
            return false;
        }
        println("网络初始化成功");
        
        /* 绑定端口 */
        bool bindResult = this.server.bindTo(this.port);
        if (!bindResult) {
            println("绑定端口失败: {}", this.port);
            return false;
        }
        println("服务器绑定到端口: {}", this.port);
        
        /* 开始监听 */
        bool listenResult = this.server.listen(5);
        if (!listenResult) {
            println("开始监听失败");
            return false;
        }
        println("服务器开始监听...");
        
        this.running = true;
        return true;
    }
    
    /**
     * 停止服务器
     */
    public void stop() {
        this.running = false;
        this.server.close();
        NetworkUtils.cleanup();
        println("服务器已停止");
    }
    
    /**
     * 检查服务器是否运行
     */
    public bool isRunning() {
        return this.running;
    }
}
