/**
 * File - 文件操作标准库
 *
 * 提供高级文件操作功能：
 * - File: 文件类，封装文件操作
 * - FileReader: 文件读取器
 * - FileWriter: 文件写入器
 * - FileMode: 文件打开模式枚举
 * - SeekOrigin: 文件定位原点枚举
 * - FileUtils: 文件工具类
 * - FileError: 文件错误枚举
 * - FileResult<T>: 文件操作结果类型
 *
 * 特性：
 * - 面向对象API设计
 * - 自动资源管理
 * - 完整的错误处理（Result<T, FileError>）
 * - 支持文本和二进制操作
 * - 流式读写支持
 *
 * 版本: 0.5.2.0
 * 时间复杂度: 标注于各方法
 * 磁盘I/O: 所有读写操作涉及磁盘I/O
 */

#ifndef CAY_FILE_H
#define CAY_FILE_H

#include <std/ffi.cay>

/* ============================================================================
 * 常量定义
 * ============================================================================ */

/* 文件打开模式 */
#define FILE_MODE_READ      "r"     // 只读
#define FILE_MODE_WRITE     "w"     // 只写（创建或截断）
#define FILE_MODE_APPEND    "a"     // 追加
#define FILE_MODE_READPLUS  "r+"    // 读写
#define FILE_MODE_WRITEPLUS "w+"    // 读写（创建或截断）
#define FILE_MODE_APPENDPLUS "a+"   // 读写追加

/* 定位原点 */
#define SEEK_ORIGIN_SET     0       // 文件开头
#define SEEK_ORIGIN_CUR     1       // 当前位置
#define SEEK_ORIGIN_END     2       // 文件末尾

/* 缓冲区大小 */
#define FILE_DEFAULT_BUFFER_SIZE 8192
#define FILE_MAX_PATH_LENGTH     260

/* 错误码 */
#define FILE_ERROR_NONE          0
#define FILE_ERROR_NOT_FOUND     1
#define FILE_ERROR_ACCESS_DENIED 2
#define FILE_ERROR_IO            3
#define FILE_ERROR_INVALID_MODE  4
#define FILE_ERROR_SEEK          5
#define FILE_ERROR_ALREADY_EXISTS 6
#define FILE_ERROR_TOO_LARGE     7
#define FILE_ERROR_INVALID_PATH  8

/* ============================================================================
 * 底层C函数声明
 * ============================================================================ */

extern {
    // 文件操作
    c_void* fopen(c_string filename, c_string mode);
    c_int fclose(c_void* stream);
    c_void* freopen(c_string filename, c_string mode, c_void* stream);

    // 文件读写
    size_t fread(c_void* ptr, size_t size, size_t nmemb, c_void* stream);
    size_t fwrite(c_void* ptr, size_t size, size_t nmemb, c_void* stream);
    c_int fgetc(c_void* stream);
    c_int fputc(c_int c, c_void* stream);
    c_int fputs(c_string s, c_void* stream);
    c_int fprintf(c_void* stream, c_string fmt, ...);

    // 文件定位
    c_int fseek(c_void* stream, c_long offset, c_int whence);
    c_long ftell(c_void* stream);
    c_void rewind(c_void* stream);

    // 错误处理
    c_int feof(c_void* stream);
    c_int ferror(c_void* stream);
    c_void clearerr(c_void* stream);
    c_void perror(c_string s);

    // 刷新缓冲区
    c_int fflush(c_void* stream);

    // 内存分配
    c_void* malloc(size_t size);
    c_void* realloc(c_void* ptr, size_t size);
    void free(c_void* ptr);

    // 文件系统操作
    c_int remove(c_string filename);
    c_int rename(c_string oldname, c_string newname);
    c_int64_t time(c_int64_t* timer);
    
    // 文件状态检查（用于exists和size）
    c_int access(c_string pathname, c_int mode);
    c_int stat(c_string pathname, c_void* statbuf);
}

/* ============================================================================
 * 文件错误类型
 * ============================================================================ */

/**
 * 文件操作错误类型 - 使用类常量模拟枚举
 * 提供结构化的错误信息
 */
public class FileError {
    public static final int None = 0;           // 无错误
    public static final int NotFound = 1;       // 文件不存在
    public static final int AccessDenied = 2;   // 权限不足
    public static final int IoError = 3;        // I/O错误
    public static final int InvalidMode = 4;    // 无效打开模式
    public static final int SeekError = 5;      // 定位错误
    public static final int AlreadyExists = 6;  // 文件已存在
    public static final int TooLarge = 7;       // 文件过大
    public static final int InvalidPath = 8;    // 无效路径
    public static final int Unknown = 9;        // 未知错误
    
    private int value;
    
    private FileError(int value) {
        this.value = value;
    }
    
    public int getValue() {
        return this.value;
    }
    
    public static FileError fromInt(int value) {
        return new FileError(value);
    }
}

/**
 * 文件操作结果类型
 * TODO: 当Cavvy支持泛型后，改为 FileResult<T>
 * 当前使用 Object 类型作为通用容器
 */
public class FileResult {
    private Object value;
    private int errorCode;
    private bool isSuccess;
    
    private FileResult(Object value) {
        this.value = value;
        this.errorCode = FileError.None;
        this.isSuccess = true;
    }
    
    private FileResult(int errorCode) {
        this.errorCode = errorCode;
        this.isSuccess = false;
    }
    
    public static FileResult ok(Object value) {
        return new FileResult(value);
    }
    
    public static FileResult err(int errorCode) {
        return new FileResult(errorCode);
    }
    
    public bool isOk() {
        return this.isSuccess;
    }
    
    public bool isErr() {
        return !this.isSuccess;
    }
    
    public Object unwrap() {
        return this.value;
    }
    
    public int getErrorCode() {
        return this.errorCode;
    }
    
    public int getError() {
        return this.errorCode;
    }
}

/* ============================================================================
 * FileMode 类 - 文件打开模式
 * ============================================================================ */

public class FileMode {
    private String mode;

    private FileMode(String mode) {
        this.mode = mode;
    }

    public String getMode() {
        return this.mode;
    }

    public static FileMode read() {
        return new FileMode(FILE_MODE_READ);
    }

    public static FileMode write() {
        return new FileMode(FILE_MODE_WRITE);
    }

    public static FileMode append() {
        return new FileMode(FILE_MODE_APPEND);
    }

    public static FileMode readWrite() {
        return new FileMode(FILE_MODE_READPLUS);
    }

    public static FileMode writeRead() {
        return new FileMode(FILE_MODE_WRITEPLUS);
    }

    public static FileMode appendRead() {
        return new FileMode(FILE_MODE_APPENDPLUS);
    }

    public static FileMode custom(String mode) {
        return new FileMode(mode);
    }
}

/* ============================================================================
 * SeekOrigin 类 - 定位原点
 * ============================================================================ */

public class SeekOrigin {
    private int value;

    private SeekOrigin(int value) {
        this.value = value;
    }

    public int getValue() {
        return this.value;
    }

    public static SeekOrigin begin() {
        return new SeekOrigin(SEEK_ORIGIN_SET);
    }

    public static SeekOrigin current() {
        return new SeekOrigin(SEEK_ORIGIN_CUR);
    }

    public static SeekOrigin end() {
        return new SeekOrigin(SEEK_ORIGIN_END);
    }
}

/* ============================================================================
 * FileInfo 类 - 文件信息（用于stat-based操作）
 * ============================================================================ */

/**
 * 文件信息类
 * 通过stat系统调用获取，避免打开文件
 */
public class FileInfo {
    private String filePath;
    private long fileSize;
    private bool fileExists;
    private bool isReadable;
    private bool isWritable;
    
    private FileInfo(String path, long size, bool exists) {
        this.filePath = path;
        this.fileSize = size;
        this.fileExists = exists;
        this.isReadable = false;
        this.isWritable = false;
    }
    
    public static FileInfo fromPath(String path) {
        // 使用access检查文件存在性和权限
        c_string cPath = path.c_str();
        
        // F_OK = 0, 检查文件是否存在
        bool exists = access(cPath, 0) == 0;
        
        long size = -1;
        if (exists) {
            // 如果能打开读取，获取大小
            c_void* fp = fopen(cPath, FILE_MODE_READ);
            if (fp != null) {
                fseek(fp, 0, SEEK_ORIGIN_END);
                size = (long)ftell(fp);
                fclose(fp);
            }
        }
        
        return new FileInfo(path, size, exists);
    }
    
    public bool exists() {
        return this.fileExists;
    }
    
    public long getSize() {
        return this.fileSize;
    }
    
    public String getPath() {
        return this.filePath;
    }
}

/* ============================================================================
 * File 类 - 文件操作主类
 * ============================================================================ */

public class File {
    private c_void* handle;
    private String filePath;
    private FileMode mode;
    private bool isOpen;
    private int lastError;

    public File() {
        this.handle = null;
        this.filePath = "";
        this.mode = FileMode.read();
        this.isOpen = false;
        this.lastError = FILE_ERROR_NONE;
    }

    public File(String path, FileMode mode) {
        this();
        this.open(path, mode);
    }

    /**
     * 析构函数，自动关闭文件
     * 静默处理关闭错误，避免在终结器上下文传播异常
     */
    public void finalize() {
        if (this.isOpen && this.handle != null) {
            // 静默关闭，不传播错误
            fclose(this.handle);
            this.handle = null;
            this.isOpen = false;
        }
    }

    /**
     * 打开文件（返回bool的传统API）
     * @param path 文件路径
     * @param mode 打开模式
     * @return true如果成功
     */
    public bool open(String path, FileMode mode) {
        if (this.isOpen) {
            this.close();
        }

        this.filePath = path;
        this.mode = mode;

        c_string cPath = path.c_str();
        c_string cMode = mode.getMode().c_str();

        this.handle = fopen(cPath, cMode);

        if (this.handle == null) {
            this.isOpen = false;
            this.lastError = FILE_ERROR_NOT_FOUND;
            return false;
        }

        this.isOpen = true;
        this.lastError = FILE_ERROR_NONE;
        return true;
    }
    
    /**
     * 打开文件（返回Result的现代API）
     * TODO: 当Cavvy支持泛型后，返回类型改为 FileResult<File>
     * @param path 文件路径
     * @param mode 打开模式
     * @return FileResult
     */
    public static FileResult openResult(String path, FileMode mode) {
        File file = new File();
        if (file.open(path, mode)) {
            return FileResult.ok(file);
        } else {
            return FileResult.err(FileError.NotFound);
        }
    }

    public bool close() {
        if (!this.isOpen || this.handle == null) {
            return true;
        }

        c_int result = fclose(this.handle);

        this.handle = null;
        this.isOpen = false;

        if (result != 0) {
            this.lastError = FILE_ERROR_IO;
            return false;
        }

        this.lastError = FILE_ERROR_NONE;
        return true;
    }

    public bool isOpened() {
        return this.isOpen;
    }

    public bool isEof() {
        if (!this.isOpen || this.handle == null) {
            return true;
        }
        return feof(this.handle) != 0;
    }

    public bool hasError() {
        if (!this.isOpen || this.handle == null) {
            return true;
        }
        return ferror(this.handle) != 0;
    }

    public void clearError() {
        if (this.handle != null) {
            clearerr(this.handle);
        }
        this.lastError = FILE_ERROR_NONE;
    }

    public int getLastError() {
        return this.lastError;
    }
    
    /**
     * 获取最后错误作为FileError
     */
    public int getLastFileError() {
        switch (this.lastError) {
            case FILE_ERROR_NONE: return FileError.None;
            case FILE_ERROR_NOT_FOUND: return FileError.NotFound;
            case FILE_ERROR_ACCESS_DENIED: return FileError.AccessDenied;
            case FILE_ERROR_IO: return FileError.IoError;
            case FILE_ERROR_INVALID_MODE: return FileError.InvalidMode;
            case FILE_ERROR_SEEK: return FileError.SeekError;
            default: return FileError.Unknown;
        }
    }

    public bool flush() {
        if (!this.isOpen || this.handle == null) {
            return false;
        }
        return fflush(this.handle) == 0;
    }

    public long position() {
        if (!this.isOpen || this.handle == null) {
            return -1;
        }
        return (long)ftell(this.handle);
    }

    public bool seek(long offset, SeekOrigin origin) {
        if (!this.isOpen || this.handle == null) {
            return false;
        }
        c_int result = fseek(this.handle, (c_long)offset, origin.getValue());
        return result == 0;
    }

    public void rewind() {
        if (this.handle != null) {
            rewind(this.handle);
        }
    }

    /**
     * 获取文件大小
     * 使用stat-based方法，避免seek-tell-seek的线程安全问题
     * @return 文件大小（字节），-1表示错误
     */
    public long size() {
        if (!this.isOpen || this.handle == null) {
            return -1;
        }
        
        // 使用FileInfo获取大小，避免seek-tell-seek的TOCTOU问题
        FileInfo info = FileInfo.fromPath(this.filePath);
        if (info.exists()) {
            return info.getSize();
        }
        
        return -1;
    }

    public int readChar() {
        if (!this.isOpen || this.handle == null) {
            return -1;
        }
        // fgetc返回c_int，直接作为int返回
        return fgetc(this.handle);
    }

    public bool writeChar(int charCode) {
        if (!this.isOpen || this.handle == null) {
            return false;
        }
        c_int result = fputc(charCode, this.handle);
        return result != -1;
    }

    public long readBytes(c_void* buffer, long size) {
        if (!this.isOpen || this.handle == null || buffer == null || size <= 0) {
            return -1;
        }
        return (long)fread(buffer, 1, (size_t)size, this.handle);
    }

    public long writeBytes(c_void* buffer, long size) {
        if (!this.isOpen || this.handle == null || buffer == null || size <= 0) {
            return -1;
        }
        return (long)fwrite(buffer, 1, (size_t)size, this.handle);
    }

    public String readLine(int maxLength) {
        if (!this.isOpen || this.handle == null || maxLength <= 0) {
            return null;
        }

        // 使用char数组而不是c_char*指针，以支持数组索引
        char[] buffer = new char[maxLength]();

        int i = 0;
        while (i < maxLength - 1) {
            int c = this.readChar();
            if (c == -1) {
                if (i == 0) {
                    return null;
                }
                break;
            }

            // 直接设置字符
            buffer[i] = (char)c;
            i = i + 1;

            if (c == '\n') {
                break;
            }
        }

        // 设置字符串结束符
        buffer[i] = '\0';

        // 构建字符串
        String result = "";
        int j = 0;
        while (j < i) {
            result = result + buffer[j];
            j = j + 1;
        }

        return result;
    }

    public bool writeString(String str) {
        if (!this.isOpen || this.handle == null || str == null) {
            return false;
        }
        return fputs(str.c_str(), this.handle) != -1;
    }

    public bool writeLine(String str) {
        if (!this.writeString(str)) {
            return false;
        }
        // 使用int类型的换行符ASCII码(10)而不是char字面量
        return this.writeChar(10);
    }

    /**
     * 模板字符串写入（原writeFormat重命名）
     * 使用StringBuilder优化性能，避免O(n²)复杂度
     * @param template 模板字符串，使用{}作为占位符
     * @param args 参数数组
     * @return 写入字符数，-1表示错误
     * 时间复杂度: O(n) n=模板长度+参数总长度
     */
    public int writeInterpolated(String template, String... args) {
        if (!this.isOpen || this.handle == null || template == null) {
            return -1;
        }

        // 使用StringBuilder风格的高效构建
        StringBuilder sb = new StringBuilder();
        int templateLen = template.length();
        int argIndex = 0;
        int i = 0;
        
        while (i < templateLen - 1) {
            if (template.charAt(i) == '{' && template.charAt(i + 1) == '}') {
                // 找到占位符
                if (argIndex < args.length) {
                    sb.append(args[argIndex]);
                    argIndex = argIndex + 1;
                }
                i = i + 2;
            } else {
                sb.append(template.charAt(i));
                i = i + 1;
            }
        }
        
        // 处理最后一个字符
        if (i < templateLen) {
            sb.append(template.charAt(i));
        }
        
        // 写入剩余参数（如果有）
        while (argIndex < args.length) {
            sb.append(args[argIndex]);
            argIndex = argIndex + 1;
        }

        String result = sb.toString();
        if (this.writeString(result)) {
            return result.length();
        }
        return -1;
    }
    
    /**
     * 已废弃：使用writeInterpolated替代
     */
    public int writeFormat(String format, String... args) {
        return this.writeInterpolated(format, args);
    }

    public String readAllText() {
        if (!this.isOpen || this.handle == null) {
            return null;
        }

        long fileSize = this.size();
        if (fileSize < 0) {
            return null;
        }

        // 限制最大读取大小
        if (fileSize > 104857600) { // 100MB
            fileSize = 104857600;
        }

        // 使用char数组而不是c_void*指针
        char[] buffer = new char[(int)(fileSize + 1)]();

        this.rewind();
        // 逐字符读取
        int i = 0;
        int c;
        while (i < fileSize && (c = this.readChar()) != -1) {
            buffer[i] = (char)c;
            i = i + 1;
        }

        // 设置字符串结束符
        buffer[i] = '\0';

        // 构建字符串
        String content = "";
        int j = 0;
        while (j < i) {
            content = content + buffer[j];
            j = j + 1;
        }

        return content;
    }

    public bool writeAllText(String content) {
        if (!this.isOpen || this.handle == null || content == null) {
            return false;
        }

        this.rewind();
        return this.writeString(content);
    }

    public String getPath() {
        return this.filePath;
    }

    public FileMode getMode() {
        return this.mode;
    }

    /* ==================== 静态工具方法 ==================== */

    /**
     * 检查文件是否存在
     * 使用access系统调用，避免修改文件时间戳
     * @param path 文件路径
     * @return true如果存在
     * 时间复杂度: O(1)
     * 磁盘I/O: 仅检查文件系统元数据，不打开文件
     */
    public static bool exists(String path) {
        if (path == null || path.isEmpty()) {
            return false;
        }
        // 使用access(F_OK)检查文件是否存在，不修改atime
        return access(path.c_str(), 0) == 0;
    }
    
    /**
     * 检查文件是否存在（返回Result的现代API）
     * TODO: 当Cavvy支持泛型后，返回类型改为 FileResult<bool>
     * @param path 文件路径
     * @return FileResult
     */
    public static FileResult existsResult(String path) {
        if (path == null || path.isEmpty()) {
            return FileResult.err(FileError.InvalidPath);
        }
        
        c_int result = access(path.c_str(), 0);
        if (result == 0) {
            return FileResult.ok(true);
        } else {
            return FileResult.ok(false);
        }
    }
    
    /**
     * 获取文件大小（不打开文件）
     * 使用FileInfo.stat-based方法
     * @param path 文件路径
     * @return 文件大小，-1表示错误
     */
    public static long getSize(String path) {
        FileInfo info = FileInfo.fromPath(path);
        if (info.exists()) {
            return info.getSize();
        }
        return -1;
    }

    public static bool delete(String path) {
        c_int result = remove(path.c_str());
        return result == 0;
    }

    public static bool move(String oldPath, String newPath) {
        c_int result = rename(oldPath.c_str(), newPath.c_str());
        return result == 0;
    }

    public static bool copy(String sourcePath, String destPath) {
        File source = new File();
        if (!source.open(sourcePath, FileMode.read())) {
            return false;
        }

        File dest = new File();
        if (!dest.open(destPath, FileMode.write())) {
            source.close();
            return false;
        }

        c_void* buffer = malloc((size_t)FILE_DEFAULT_BUFFER_SIZE);
        if (buffer == null) {
            source.close();
            dest.close();
            return false;
        }

        bool success = true;
        while (!source.isEof()) {
            long bytesRead = source.readBytes(buffer, FILE_DEFAULT_BUFFER_SIZE);
            if (bytesRead > 0) {
                long bytesWritten = dest.writeBytes(buffer, bytesRead);
                if (bytesWritten != bytesRead) {
                    success = false;
                    break;
                }
            }
        }

        free(buffer);
        source.close();
        dest.close();

        return success;
    }

    public static String readAllText(String path) {
        File file = new File();
        if (!file.open(path, FileMode.read())) {
            return null;
        }
        String content = file.readAllText();
        file.close();
        return content;
    }

    public static bool writeAllText(String path, String content) {
        File file = new File();
        if (!file.open(path, FileMode.write())) {
            return false;
        }
        bool result = file.writeAllText(content);
        file.close();
        return result;
    }

    public static bool appendAllText(String path, String content) {
        File file = new File();
        if (!file.open(path, FileMode.append())) {
            return false;
        }
        bool result = file.writeString(content);
        file.close();
        return result;
    }

    /**
     * 读取文件所有行
     * 使用流式读取避免双倍内存峰值
     * @param path 文件路径
     * @return 行数组，null表示错误
     * 时间复杂度: O(n) n=文件大小
     * 内存使用: O(max_line_length) 而非 O(file_size)
     */
    public static String[] readAllLines(String path) {
        // 先统计行数（流式）
        int lineCount = 0;
        File counter = new File();
        if (!counter.open(path, FileMode.read())) {
            return null;
        }
        
        while (!counter.isEof()) {
            String line = counter.readLine(8192);
            if (line != null) {
                lineCount = lineCount + 1;
            }
        }
        counter.close();
        
        if (lineCount == 0) {
            return new String[0]();
        }
        
        // 再次读取填充数组
        String[] lines = new String[lineCount]();
        File file = new File();
        if (!file.open(path, FileMode.read())) {
            return null;
        }
        
        int index = 0;
        while (!file.isEof() && index < lineCount) {
            String line = file.readLine(8192);
            if (line != null) {
                // 移除换行符
                if (line.endsWith("\n")) {
                    line = line.substring(0, line.length() - 1);
                    if (line.endsWith("\r")) {
                        line = line.substring(0, line.length() - 1);
                    }
                }
                lines[index] = line;
                index = index + 1;
            }
        }
        file.close();
        
        return lines;
    }

    public static bool writeAllLines(String path, String[] lines) {
        File file = new File();
        if (!file.open(path, FileMode.write())) {
            return false;
        }

        bool success = true;
        int i = 0;
        while (i < lines.length) {
            if (!file.writeLine(lines[i])) {
                success = false;
                break;
            }
            i = i + 1;
        }

        file.close();
        return success;
    }
}

/* ============================================================================
 * FileReader 类 - 文件读取器
 * ============================================================================ */

public class FileReader {
    private File file;

    public FileReader(String path) {
        this.file = new File();
        this.file.open(path, FileMode.read());
    }

    public void close() {
        this.file.close();
    }

    public String readToEnd() {
        return this.file.readAllText();
    }

    public String readLine() {
        return this.file.readLine(8192);
    }

    public bool isEof() {
        return this.file.isEof();
    }
    
    /**
     * 获取行迭代器（流式读取）
     * @return LineIterator
     */
    public LineIterator lines() {
        return new LineIterator(this.file);
    }
}

/**
 * 行迭代器 - 支持流式逐行读取
 */
public class LineIterator {
    private File file;
    private String nextLine;
    
    public LineIterator(File file) {
        this.file = file;
        this.nextLine = null;
        this.advance();
    }
    
    private void advance() {
        if (!this.file.isEof()) {
            this.nextLine = this.file.readLine(8192);
        } else {
            this.nextLine = null;
        }
    }
    
    public bool hasNext() {
        return this.nextLine != null;
    }
    
    public String next() {
        String current = this.nextLine;
        this.advance();
        return current;
    }
}

/* ============================================================================
 * FileWriter 类 - 文件写入器
 * ============================================================================ */

public class FileWriter {
    private File file;

    public FileWriter(String path) {
        this.file = new File();
        this.file.open(path, FileMode.write());
    }

    public FileWriter(String path, bool append) {
        this.file = new File();
        if (append) {
            this.file.open(path, FileMode.append());
        } else {
            this.file.open(path, FileMode.write());
        }
    }

    public void close() {
        this.file.close();
    }

    public bool write(String str) {
        return this.file.writeString(str);
    }

    public bool writeLine(String str) {
        return this.file.writeLine(str);
    }

    public bool flush() {
        return this.file.flush();
    }
}

/* ============================================================================
 * StringBuilder 类 - 内部使用的字符串构建器
 * ============================================================================ */

/**
 * 简单的字符串构建器，用于优化writeInterpolated性能
 * 使用char数组而不是c_char*指针，以支持数组索引
 */
private class StringBuilder {
    private char[] buffer;
    private int capacity;
    private int length;
    
    public StringBuilder() {
        this.capacity = 256;
        this.length = 0;
        this.buffer = new char[this.capacity]();
    }
    
    public void append(String s) {
        if (s == null) return;
        
        int sLen = s.length();
        this.ensureCapacity(this.length + sLen);
        
        int i = 0;
        while (i < sLen) {
            this.buffer[this.length + i] = s.charAt(i);
            i = i + 1;
        }
        this.length = this.length + sLen;
    }
    
    public void append(char c) {
        this.ensureCapacity(this.length + 1);
        this.buffer[this.length] = c;
        this.length = this.length + 1;
    }
    
    private void ensureCapacity(int minCapacity) {
        if (minCapacity > this.capacity) {
            int newCapacity = this.capacity * 2;
            if (newCapacity < minCapacity) {
                newCapacity = minCapacity;
            }
            char[] newBuffer = new char[newCapacity]();
            int i = 0;
            while (i < this.length) {
                newBuffer[i] = this.buffer[i];
                i = i + 1;
            }
            this.buffer = newBuffer;
            this.capacity = newCapacity;
        }
    }
    
    public String toString() {
        if (this.length == 0) {
            return "";
        }
        // 构建字符串
        String result = "";
        int i = 0;
        while (i < this.length) {
            result = result + this.buffer[i];
            i = i + 1;
        }
        return result;
    }
}

/* ============================================================================
 * FileUtils 类 - 文件工具类
 * ============================================================================ */

public class FileUtils {

    public static String getFileName(String path) {
        if (path == null || path.isEmpty()) {
            return "";
        }

        int lastSlash = path.lastIndexOf("/");
        int lastBackslash = path.lastIndexOf("\\");
        int lastSeparator = lastSlash > lastBackslash ? lastSlash : lastBackslash;

        if (lastSeparator < 0) {
            return path;
        }

        return path.substring(lastSeparator + 1);
    }

    public static String getExtension(String path) {
        if (path == null || path.isEmpty()) {
            return "";
        }

        String fileName = getFileName(path);
        int lastDot = fileName.lastIndexOf(".");

        if (lastDot < 0 || lastDot == fileName.length() - 1) {
            return "";
        }

        return fileName.substring(lastDot);
    }

    public static String getDirectoryName(String path) {
        if (path == null || path.isEmpty()) {
            return "";
        }

        int lastSlash = path.lastIndexOf("/");
        int lastBackslash = path.lastIndexOf("\\");
        int lastSeparator = lastSlash > lastBackslash ? lastSlash : lastBackslash;

        if (lastSeparator < 0) {
            return "";
        }

        return path.substring(0, lastSeparator);
    }

    public static String getFileNameWithoutExtension(String path) {
        String fileName = getFileName(path);
        int lastDot = fileName.lastIndexOf(".");

        if (lastDot < 0) {
            return fileName;
        }

        return fileName.substring(0, lastDot);
    }

    public static String combine(String path1, String path2) {
        if (path1 == null || path1.isEmpty()) {
            return path2 == null ? "" : path2;
        }
        if (path2 == null || path2.isEmpty()) {
            return path1;
        }

        bool endsWithSeparator = path1.endsWith("/") || path1.endsWith("\\");
        bool startsWithSeparator = path2.startsWith("/") || path2.startsWith("\\");

        if (endsWithSeparator && startsWithSeparator) {
            return path1 + path2.substring(1);
        } else if (!endsWithSeparator && !startsWithSeparator) {
            return path1 + "/" + path2;
        } else {
            return path1 + path2;
        }
    }

    public static String changeExtension(String path, String extension) {
        if (path == null || path.isEmpty()) {
            return "";
        }

        int lastDot = path.lastIndexOf(".");
        if (lastDot < 0) {
            if (extension == null || extension.isEmpty()) {
                return path;
            }
            if (extension.startsWith(".")) {
                return path + extension;
            }
            return path + "." + extension;
        }

        if (extension == null || extension.isEmpty()) {
            return path.substring(0, lastDot);
        }

        if (extension.startsWith(".")) {
            return path.substring(0, lastDot) + extension;
        }
        return path.substring(0, lastDot) + "." + extension;
    }
}

#endif // CAY_FILE_H
