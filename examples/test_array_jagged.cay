// 大型测试：不规则数组 (Jagged Array)
public class TestArrayJagged {
    
    public static void main() {
        println("=== Jagged Array Tests ===");
        
        // 创建不规则数组 - 使用多维数组语法
        int[][] jagged = new int[5][];
        jagged[0] = new int[1];
        jagged[1] = new int[2];
        jagged[2] = new int[3];
        jagged[3] = new int[4];
        jagged[4] = new int[5];
        
        // 初始化数据
        int i;
        int j;
        for (i = 0; i < 5; i++) {
            for (j = 0; j <= i; j++) {
                jagged[i][j] = (i + 1) * 10 + j;
            }
        }
        
        // 打印不规则数组
        println("Jagged array contents:");
        for (i = 0; i < 5; i++) {
            print("Row ");
            print(i);
            print(" (length=");
            print(jagged[i].length);
            print("): ");
            for (j = 0; j < jagged[i].length; j++) {
                print(jagged[i][j]);
                print(" ");
            }
            println("");
        }
        
        // 验证行长度
        boolean lengthsCorrect = true;
        if (jagged[0].length != 1) lengthsCorrect = false;
        if (jagged[1].length != 2) lengthsCorrect = false;
        if (jagged[2].length != 3) lengthsCorrect = false;
        if (jagged[3].length != 4) lengthsCorrect = false;
        if (jagged[4].length != 5) lengthsCorrect = false;
        
        if (lengthsCorrect) {
            println("\nJagged array length test PASSED!");
        } else {
            println("\nJagged array length test FAILED!");
        }
        
        // 计算总元素数
        int totalElements = 0;
        for (i = 0; i < 5; i++) {
            totalElements = totalElements + jagged[i].length;
        }
        print("Total elements: ");
        println(totalElements);
        
        // 计算总和
        int sum = 0;
        for (i = 0; i < 5; i++) {
            for (j = 0; j < jagged[i].length; j++) {
                sum = sum + jagged[i][j];
            }
        }
        
        print("Sum of all elements: ");
        println(sum);
        
        println("\nJagged array tests completed!");
    }
}
