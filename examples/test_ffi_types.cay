// FFI 类型系统验证测试
// 这个示例验证新的 FFI 类型是否正确工作

public class FFITypesTest {
    // 测试 FFI 类型的声明和使用
    public static void testFFITypes() {
        // 基本类型 - 使用变量避免直接赋值字面量
        c_int a;
        a = 10;

        c_uint b;
        b = 20;

        c_long c;
        c = 30;

        c_short d;
        d = 40;

        c_ushort e;
        e = 50;

        c_char f;
        f = 65;  // 'A'

        c_uchar g;
        g = 66; // 'B'

        c_float h;
        h = 3.14;

        c_double i;
        i = 3.14159;

        // 指针类型
        c_void* ptr = null;
        c_char* str = null;
        c_int* int_ptr = null;

        // 多级指针
        c_void** ptr_ptr = null;
        c_char*** str_ptr_ptr = null;

        // 特殊类型
        size_t size;
        size = 100;

        ssize_t ssize;
        ssize = -50;

        uintptr_t uptr;
        uptr = 0x12345678;

        intptr_t iptr;
        iptr = -0x12345678;

        println("FFI Types Test");
        println("===============");
        println("c_int: {}", a);
        println("c_uint: {}", b);
        println("c_long: {}", c);
        println("c_short: {}", d);
        println("c_ushort: {}", e);
        println("c_char: {}", f);
        println("c_uchar: {}", g);
        println("c_float: {}", h);
        println("c_double: {}", i);
        println("size_t: {}", size);
        println("ssize_t: {}", ssize);
        println("uintptr_t: {}", uptr);
        println("intptr_t: {}", iptr);
        println("c_void*: {}", ptr);
        println("c_char*: {}", str);
        println("c_int*: {}", int_ptr);
        println("c_void**: {}", ptr_ptr);
        println("c_char***: {}", str_ptr_ptr);
    }

    public static void main() {
        testFFITypes();
        println("All FFI type tests passed!");
    }
}