/**
 * UDP 简单测试
 */

#include <Network.cay>

public int main() {
    println("=== UDP简单测试 ===");
    
    /* 初始化网络 */
    if (!NetworkUtils.init()) {
        println("网络初始化失败");
        return 1;
    }
    println("网络初始化成功");
    
    /* 创建UDP Socket */
    long sock = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
    if (sock == INVALID_SOCKET) {
        println("创建UDP Socket失败");
        NetworkUtils.cleanup();
        return 1;
    }
    println("UDP Socket创建成功");
    
    /* 创建地址结构 */
    SocketAddr addr = new SocketAddr().any(12346);
    println("SocketAddr创建完成");
    
    /* 直接调用bind */
    int bindResult = bind((int)sock, (long)(&addr), 16);
    if (bindResult != 0) {
        println("绑定失败，结果: " + bindResult);
        closesocket(sock);
        NetworkUtils.cleanup();
        return 1;
    }
    println("绑定成功到端口12346");
    
    /* 关闭 */
    closesocket(sock);
    NetworkUtils.cleanup();
    
    println("=== 测试完成 ===");
    return 0;
}
