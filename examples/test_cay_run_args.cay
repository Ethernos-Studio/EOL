// 测试 cay-run 传递参数功能的示例程序
// 使用: cay-run test_cay_run_args.cay -- arg1 arg2 arg3

public class Main {
    public static int main(String[] args) {
        println("Testing cay-run with arguments!");
        println("Number of arguments: " + args.length);
        
        if (args.length > 0) {
            println("Arguments received:");
            for (int i = 0; i < args.length; i = i + 1) {
                println("  [" + i + "] = " + args[i]);
            }
        } else {
            println("No arguments provided.");
            println("Try running with: cay-run test_cay_run_args.cay -- hello world");
        }
        
        return 0;
    }
}
