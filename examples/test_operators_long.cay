public class TestOperatorsLong {
    public static void main() {
        // 测试 int 类型的运算符（验证类型转换问题是否修复）
        int a = 15;
        int b = 4;
        
        int sum = a + b;        // 19
        int diff = a - b;       // 11
        int prod = a * b;       // 60
        int quot = a / b;       // 3 (整数除法)
        int mod = a % b;        // 3
        
        print("Arithmetic operators test (int):\n");
        print("a + b = ");
        print(sum);
        println("");
        print("a - b = ");
        print(diff);
        println("");
        print("a * b = ");
        print(prod);
        println("");
        print("a / b = ");
        print(quot);
        println("");
        print("a % b = ");
        print(mod);
        println("");
        
        // 关系运算符测试
        bool eq = a == b;       // false
        bool ne = a != b;       // true
        bool lt = a < b;        // false
        bool le = a <= b;       // false
        bool gt = a > b;        // true
        bool ge = a >= b;       // true
        
        print("\nRelational operators test:\n");
        print("a == b: ");
        if (eq) { print("true"); } else { print("false"); }
        println("");
        print("a != b: ");
        if (ne) { print("true"); } else { print("false"); }
        println("");
        print("a < b: ");
        if (lt) { print("true"); } else { print("false"); }
        println("");
        print("a <= b: ");
        if (le) { print("true"); } else { print("false"); }
        println("");
        print("a > b: ");
        if (gt) { print("true"); } else { print("false"); }
        println("");
        print("a >= b: ");
        if (ge) { print("true"); } else { print("false"); }
        println("");
        
        // 逻辑运算符测试
        bool x = true;
        bool y = false;
        bool and = x && y;      // false
        bool or = x || y;       // true
        bool not = !x;          // false
        
        print("\nLogical operators test:\n");
        print("x && y: ");
        if (and) { print("true"); } else { print("false"); }
        println("");
        print("x || y: ");
        if (or) { print("true"); } else { print("false"); }
        println("");
        print("!x: ");
        if (not) { print("true"); } else { print("false"); }
        println("");
        
        // 位运算符测试（int 也支持位运算）
        int m = 12;
        int n = 10;
        
        int bitAnd = m & n;     // 8
        int bitOr = m | n;      // 14
        int bitXor = m ^ n;     // 6
        int bitNot = ~m;        // 按位取反
        int shiftLeft = m << 2; // 48
        int shiftRight = m >> 1; // 6
        
        print("\nBitwise operators test:\n");
        print("m & n = ");
        print(bitAnd);
        println("");
        print("m | n = ");
        print(bitOr);
        println("");
        print("m ^ n = ");
        print(bitXor);
        println("");
        print("~m = ");
        print(bitNot);
        println("");
        print("m << 2 = ");
        print(shiftLeft);
        println("");
        print("m >> 1 = ");
        print(shiftRight);
        println("");
        
        print("\nAll operator tests completed successfully!\n");
    }
}
