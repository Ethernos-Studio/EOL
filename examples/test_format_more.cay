/**
 * Format 打印功能更多测试
 */

public int main() {
    println("=== Format 更多测试 ===");

    /* 测试: 字符串变量 */
    String name = "Alice";
    println("Name: %s", name);

    /* 测试: 两个字符串 */
    String first = "Hello";
    String last = "World";
    println("%s %s!", first, last);

    /* 测试: 混合类型 */
    String user = "Bob";
    int score = 95;
    println("User: %s, Score: %d", user, score);

    /* 测试: 不换行 */
    print("Loading");
    print(".");
    print(".");
    println(". Done!");

    println("=== 测试完成 ===");
    return 0;
}
