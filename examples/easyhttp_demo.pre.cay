/* ============================================================================
 * 基础Socket类
 * ============================================================================ */

/**
 * 基础Socket类
 * 提供通用的Socket操作
 */
public class Socket {
    protected long handle;
    protected int family;
    protected int type;
    protected int protocol;
    protected bool connected;
    protected bool bound;
    
    /**
     * 创建Socket
     * @param family 地址族 (2, 23)
     * @param type Socket类型 (1, 2)
     * @param protocol 协议 (6, 17, 0)
     */
    public Socket(int family, int type, int protocol) {
        this.family = family;
        this.type = type;
        this.protocol = protocol;
        this.connected = false;
        this.bound = false;
        this.handle = (long)(-1);
    }
    
    /**
     * 获取Socket句柄
     * @return Socket句柄
     */
    public long getHandle() {
        return this.handle;
    }
    
    /**
     * 设置Socket句柄 (供子类使用)
     * @param h 新的句柄值
     */
    protected void setHandle(long h) {
        this.handle = h;
    }
    
    /**
     * 检查Socket是否有效
     * @return true如果Socket有效
     */
    public bool isValid() {
        return this.handle != (long)(-1);
    }
    
    /**
     * 检查是否已连接
     * @return true如果已连接
     */
    public bool isConnected() {
        return this.connected;
    }
    
    /**
     * 设置连接状态 (供子类使用)
     * @param c 连接状态
     */
    protected void setConnected(bool c) {
        this.connected = c;
    }
    
    /**
     * 检查是否已绑定
     * @return true如果已绑定
     */
    public bool isBound() {
        return this.bound;
    }
    
    /**
     * 设置绑定状态 (供子类使用)
     * @param b 绑定状态
     */
    protected void setBound(bool b) {
        this.bound = b;
    }
    
    /**
     * 关闭Socket
     */
    public void close() {
        if (this.handle != (long)(-1)) {

            closesocket(this.handle);



            this.handle = (long)(-1);
            this.connected = false;
            this.bound = false;
        }
    }
    
    /**
     * 设置Socket选项
     * @param level 选项级别
     * @param optname 选项名称
     * @param optval 选项值
     * @return true如果成功
     */
    public bool setOption(int level, int optname, int optval) {
        if (this.handle == (long)(-1)) {
            return false;
        }
        int result = setsockopt((int)this.handle, level, optname, (long)(&optval), 4);
        return result != (long)(-1);
    }
    
    /**
     * 设置地址重用选项
     * @param reuse true启用重用
     * @return true如果成功
     */
    public bool setReuseAddr(bool reuse) {
        int value = reuse ? 1 : 0;
        return this.setOption(0xFFFF, 0x0004, value);
    }
    
    /**
     * 设置发送超时
     * @param milliseconds 超时毫秒数
     * @return true如果成功
     */
    public bool setSendTimeout(int milliseconds) {
        return this.setOption(0xFFFF, 0x1005, milliseconds);
    }
    
    /**
     * 设置接收超时
     * @param milliseconds 超时毫秒数
     * @return true如果成功
     */
    public bool setRecvTimeout(int milliseconds) {
        return this.setOption(0xFFFF, 0x1006, milliseconds);
    }
    
    /**
     * 设置0x0001选项 (禁用Nagle算法)
     * @param enable true启用
     * @return true如果成功
     */
    public bool setTcpNoDelay(bool enable) {
        int value = enable ? 1 : 0;
        return this.setOption(6, 0x0001, value);
    }
    
    /**
     * 设置发送缓冲区大小
     * @param size 缓冲区大小
     * @return true如果成功
     */
    public bool setSendBufferSize(int size) {
        return this.setOption(0xFFFF, 0x1001, size);
    }
    
    /**
     * 设置接收缓冲区大小
     * @param size 缓冲区大小
     * @return true如果成功
     */
    public bool setRecvBufferSize(int size) {
        return this.setOption(0xFFFF, 0x1002, size);
    }
    
    /**
     * 获取最后的错误码
     * @return 错误码
     */
    public static int getLastError() {

        return WSAGetLastError();



    }
}

/* ============================================================================
 * TCP Socket类
 * ============================================================================ */

/**
 * TCP客户端Socket
 */
public class TcpSocket extends Socket {
    
    /**
     * 创建TCP Socket
     */
    public TcpSocket() {
        super(2, 1, 6);
        this.setHandle(socket(2, 1, 6));
    }
    
    /**
     * 使用现有句柄创建TCP Socket
     * @param handle Socket句柄
     */
    public static TcpSocket fromHandle(long handle) {
        TcpSocket sock = new TcpSocket();
        sock.setHandle(handle);
        sock.setConnected(true);
        return sock;
    }
    
    /**
     * 连接到服务器
     * @param addr 服务器地址
     * @return true如果连接成功
     */
    public bool connect(SocketAddr addr) {
        if (this.getHandle() == (long)(-1)) {
            return false;
        }
        
        int result = connect((int)this.getHandle(), (long)(&addr), 16);
        if (result == 0) {
            this.setConnected(true);
            return true;
        }
        return false;
    }
    
    /**
     * 连接到指定的IP和端口
     * @param ip IP地址
     * @param port 端口号
     * @return true如果连接成功
     */
    public bool connectTo(String ip, int port) {
        SocketAddr addr = new SocketAddr().fromIpPort(ip, port);
        return this.connect(addr);
    }
    
    /**
     * 发送数据
     * @param data 要发送的数据
     * @return 发送的字节数，-1表示错误
     */
    public int send(String data) {
        if (this.getHandle() == (long)(-1) || !this.isConnected()) {
            return -1;
        }
        
        int len = data.length();
        long ptr = (long)(data.c_str());
        
        long result = send((int)this.getHandle(), ptr, len, 0);
        return (int)result;
    }
    
    /**
     * 发送字节数据
     * @param buffer 数据缓冲区
     * @param length 数据长度
     * @return 发送的字节数，-1表示错误
     */
    public int sendBytes(long buffer, int length) {
        if (this.getHandle() == (long)(-1) || !this.connected) {
            return -1;
        }
        
        long result = send((int)this.getHandle(), buffer, length, 0);
        return (int)result;
    }
    
    /**
     * 接收数据
     * @param buffer 接收缓冲区
     * @param maxLength 最大接收长度
     * @return 接收的字节数，0表示连接关闭，-1表示错误
     */
    public int receive(long buffer, int maxLength) {
        if (this.getHandle() == (long)(-1) || !this.connected) {
            return -1;
        }
        
        long result = recv((int)this.getHandle(), buffer, maxLength, 0);
        return (int)result;
    }
    
    /**
     * 接收数据到字符串
     * @param maxLength 最大接收长度
     * @return 接收到的字符串
     */
    public String receiveString(int maxLength) {
        if (maxLength <= 0) {
            maxLength = 1024;
        }
        
        long buffer = malloc(maxLength);
        if (buffer == 0) {
            return "";
        }
        
        int received = this.receive(buffer, maxLength);
        String result = "";
        
        if (received > 0) {
            result = NetworkUtils.bufferToString(buffer, received);
        }
        
        free(buffer);
        return result;
    }
    
    /**
     * 优雅地关闭连接
     * @param how 关闭方式 (0, 1, 2)
     */
    public void shutdown(int how) {
        if (this.getHandle() != (long)(-1)) {
            shutdown((int)this.getHandle(), how);
        }
    }
}

/* ============================================================================
 * TCP服务器类
 * ============================================================================ */

/**
 * TCP服务器
 */
public class TcpServer {
    private long handle;
    private int port;
    private bool listening;
    
    /**
     * 创建TCP服务器
     */
    public TcpServer() {
        this.handle = (long)(-1);
        this.port = 0;
        this.listening = false;
    }
    
    /**
     * 绑定到指定地址
     * @param addr 绑定地址
     * @return true如果成功
     */
    public bool bind(SocketAddr addr) {
        this.handle = socket(2, 1, 6);
        if (this.handle == (long)(-1)) {
            return false;
        }
        
        /* 设置地址重用 */
        int reuse = 1;
        setsockopt((int)this.handle, 0xFFFF, 0x0004, (long)(&reuse), 4);
        
        /* 调用系统bind函数 */
        int sysResult = bind(this.handle, (long)(&addr), 16);
        if (sysResult == 0) {
            /* 从word0中提取端口号 (word0 = (port_network << 16) | family) */
            int portNetwork = (addr.word0 >> 16) & 0xFFFF;
            this.port = NetworkUtils.ntohs(portNetwork);
            return true;
        }
        
        this.close();
        return false;
    }
    
    /**
     * 绑定到指定端口
     * @param port 端口号
     * @return true如果成功
     */
    public bool bindTo(int port) {
        SocketAddr addr = new SocketAddr().any(port);
        bool bindResult = this.bind(addr);
        return bindResult;
    }
    
    /**
     * 开始监听
     * @param backlog 连接队列长度
     * @return true如果成功
     */
    public bool listen(int backlog) {
        if (this.handle == (long)(-1)) {
            return false;
        }
        
        int result = listen((int)this.handle, backlog);
        if (result == 0) {
            this.listening = true;
            return true;
        }
        return false;
    }
    
    /**
     * 接受连接
     * @return 客户端Socket，null表示错误
     */
    public TcpSocket accept() {
        if (this.handle == (long)(-1) || !this.listening) {
            return null;
        }
        
        long clientHandle = accept((int)this.handle, 0, 0);
        if (clientHandle == (long)(-1)) {
            return null;
        }
        
        return TcpSocket.fromHandle(clientHandle);
    }
    
    /**
     * 获取服务器端口
     * @return 端口号
     */
    public int getPort() {
        return this.port;
    }
    
    /**
     * 检查是否正在监听
     * @return true如果正在监听
     */
    public bool isListening() {
        return this.listening;
    }
    
    /**
     * 关闭服务器
     */
    public void close() {
        if (this.handle != (long)(-1)) {

            closesocket(this.handle);



            this.handle = (long)(-1);
            this.listening = false;
            this.port = 0;
        }
    }
}

/* ============================================================================
 * UDP Socket类
 * ============================================================================ */

/**
 * UDP Socket
 */
public class UdpSocket extends Socket {
    
    /**
     * 创建UDP Socket
     */
    public UdpSocket() {
        super(2, 2, 17);
        this.setHandle(socket(2, 2, 17));
    }
    
    /**
     * 绑定到指定地址
     * @param addr 绑定地址
     * @return true如果成功
     */
    public bool bind(SocketAddr addr) {
        if (this.getHandle() == (long)(-1)) {
            return false;
        }
        
        int result = bind((int)this.getHandle(), (long)(&addr), 16);
        if (result == 0) {
            this.setBound(true);
            return true;
        }
        return false;
    }
    
    /**
     * 绑定到指定端口
     * @param port 端口号
     * @return true如果成功
     */
    public bool bindTo(int port) {
        SocketAddr addr = new SocketAddr().any(port);
        return this.bind(addr);
    }
    
    /**
     * 发送数据到指定地址
     * @param data 要发送的数据
     * @param addr 目标地址
     * @return 发送的字节数，-1表示错误
     */
    public int sendTo(String data, SocketAddr addr) {
        if (this.getHandle() == (long)(-1)) {
            return -1;
        }
        
        int len = data.length();
        long ptr = (long)(data.c_str());
        
        long result = sendto((int)this.getHandle(), ptr, len, 0, (long)(&addr), 16);
        return (int)result;
    }
    
    /**
     * 发送字节数据到指定地址
     * @param buffer 数据缓冲区
     * @param length 数据长度
     * @param addr 目标地址
     * @return 发送的字节数，-1表示错误
     */
    public int sendBytesTo(long buffer, int length, SocketAddr addr) {
        if (this.getHandle() == (long)(-1)) {
            return -1;
        }
        
        long result = sendto((int)this.getHandle(), buffer, length, 0, (long)(&addr), 16);
        return (int)result;
    }
    
    /**
     * 发送数据到指定IP和端口
     * @param data 要发送的数据
     * @param ip 目标IP
     * @param port 目标端口
     * @return 发送的字节数，-1表示错误
     */
    public int sendToIpPort(String data, String ip, int port) {
        SocketAddr addr = new SocketAddr().fromIpPort(ip, port);
        return this.sendTo(data, addr);
    }
    
    /**
     * 接收数据
     * @param buffer 接收缓冲区
     * @param maxLength 最大接收长度
     * @param fromAddr 发送方地址 (输出参数)
     * @return 接收的字节数，-1表示错误
     */
    public int receiveFrom(long buffer, int maxLength, SocketAddr fromAddr) {
        if (this.getHandle() == (long)(-1)) {
            return -1;
        }
        
        int addrLen = 16;
        long result = recvfrom((int)this.getHandle(), buffer, maxLength, 0, (long)(&fromAddr), (long)(&addrLen));
        return (int)result;
    }
    
    /**
     * 接收数据到字符串
     * @param maxLength 最大接收长度
     * @param fromAddr 发送方地址 (输出参数)
     * @return 接收到的字符串
     */
    public String receiveStringFrom(int maxLength, SocketAddr fromAddr) {
        if (maxLength <= 0) {
            maxLength = 1024;
        }
        
        long buffer = malloc(maxLength);
        if (buffer == 0) {
            return "";
        }
        
        int received = this.receiveFrom(buffer, maxLength, fromAddr);
        String result = "";
        
        if (received > 0) {
            result = NetworkUtils.bufferToString(buffer, received);
        }
        
        free(buffer);
        return result;
    }
}

/* ============================================================================
 * 网络工具类
 * ============================================================================ */

/**
 * 网络工具类
 * 提供字节序转换、初始化、辅助函数等
 */
public class NetworkUtils {
    
    /**
     * 初始化网络库 (Windows需要)
     * @return true如果成功
     */
    public static bool init() {

        int version = 0x0202;
        long wsaData = malloc(400);
        if (wsaData == 0) {
            return false;
        }
        int result = WSAStartup(version, wsaData);
        free(wsaData);
        return result == 0;



    }
    
    /**
     * 清理网络库 (Windows需要)
     */
    public static void cleanup() {

        WSACleanup();

    }
    
    /**
     * 主机字节序转网络字节序 (16位)
     * 假设小端系统 (x86/x86_64)
     * @param hostshort 主机字节序的16位整数
     * @return 网络字节序的16位整数
     */
    public static int htons(int hostshort) {
        return ((hostshort & 0xFF) << 8) | ((hostshort >> 8) & 0xFF);
    }
    
    /**
     * 主机字节序转网络字节序 (32位)
     * 假设小端系统 (x86/x86_64)
     * @param hostlong 主机字节序的32位整数
     * @return 网络字节序的32位整数
     */
    public static int htonl(int hostlong) {
        return ((hostlong & 0xFF) << 24) |
               ((hostlong & 0xFF00) << 8) |
               ((hostlong >> 8) & 0xFF00) |
               ((hostlong >> 24) & 0xFF);
    }
    
    /**
     * 网络字节序转主机字节序 (16位)
     * @param netshort 网络字节序的16位整数
     * @return 主机字节序的16位整数
     */
    public static int ntohs(int netshort) {
        return htons(netshort);
    }
    
    /**
     * 网络字节序转主机字节序 (32位)
     * @param netlong 网络字节序的32位整数
     * @return 主机字节序的32位整数
     */
    public static int ntohl(int netlong) {
        return htonl(netlong);
    }
    
    /**
     * 将缓冲区转换为字符串
     * @param buffer 缓冲区指针
     * @param length 数据长度
     * @return 字符串
     * @note 使用运行时函数 __cay_buffer_to_string
     */
    public static String bufferToString(long buffer, int length) {
        /* 调用运行时函数将缓冲区转换为字符串 */
        return __cay_buffer_to_string(buffer, length);
    }
    
    /**
     * 解析IP地址
     * @param ip IP地址字符串
     * @return 网络字节序的地址，-1表示错误
     */
    public static long parseIp(String ip) {
        return inet_addr(ip.c_str());
    }
    
    /**
     * 获取主机名对应的IP地址
     * @param hostname 主机名
     * @return IP地址字符串
     */
    public static String resolveHost(String hostname) {
        long hostent = gethostbyname(hostname.c_str());
        if (hostent == 0) {
            return "";
        }
        /* hostent结构: h_name(8), h_aliases(8), h_addrtype(4), h_length(4), h_addr_list(8) */
        /* h_addr_list指向地址列表，我们取第一个 */
        long addr_list = __cay_read_ptr(hostent + 24);
        if (addr_list == 0) {
            return "";
        }
        long addr = __cay_read_ptr(addr_list);
        if (addr == 0) {
            return "";
        }
        /* 使用inet_ntoa将地址转换为字符串 */
        return __cay_ptr_to_string(inet_ntoa(addr));
    }
    
    /**
     * 获取主机名对应的IP地址（内部实现，使用C字符串）
     * @param hostnamePtr 主机名C字符串指针
     * @return IP地址字符串
     */
    private static String resolveHostInternal(long hostnamePtr) {
        long hostent = gethostbyname(hostnamePtr);
        if (hostent == 0) {
            return "";
        }
        /* hostent结构: h_name(8), h_aliases(8), h_addrtype(4), h_length(4), h_addr_list(8) */
        long addr_list = __cay_read_ptr(hostent + 24);
        if (addr_list == 0) {
            return "";
        }
        long addr = __cay_read_ptr(addr_list);
        if (addr == 0) {
            return "";
        }
        return __cay_ptr_to_string(inet_ntoa(addr));
    }
    
    /**
     * 创建TCP客户端并连接到服务器
     * @param ip 服务器IP
     * @param port 服务器端口
     * @return 连接的TcpSocket，null表示失败
     */
    public static TcpSocket connectTcp(String ip, int port) {
        if (!NetworkUtils.init()) {
            return null;
        }
        
        TcpSocket socket = new TcpSocket();
        if (!socket.connectTo(ip, port)) {
            socket.close();
            return null;
        }
        
        return socket;
    }
    
    /**
     * 创建TCP服务器并监听端口
     * @param port 监听端口
     * @param backlog 连接队列长度
     * @return 监听的TcpServer，null表示失败
     */
    public static TcpServer listenTcp(int port, int backlog) {
        if (!NetworkUtils.init()) {
            return null;
        }
        
        TcpServer server = new TcpServer();
        if (!server.bindTo(port)) {
            server.close();
            return null;
        }
        
        if (!server.listen(backlog)) {
            server.close();
            return null;
        }
        
        return server;
    }
    
    /**
     * 创建UDP Socket并绑定到端口
     * @param port 绑定端口 (0表示任意端口)
     * @return 绑定的UdpSocket，null表示失败
     */
    public static UdpSocket createUdp(int port) {
        if (!NetworkUtils.init()) {
            return null;
        }
        
        UdpSocket socket = new UdpSocket();
        
        if (port > 0) {
            if (!socket.bindTo(port)) {
                socket.close();
                return null;
            }
        }
        
        return socket;
    }
}



