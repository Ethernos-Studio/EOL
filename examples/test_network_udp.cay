/**
 * UDP Socket测试
 * 测试UDP socket的创建、绑定、发送和接收功能
 */

#include <Network.cay>

public class TestUdpSocket {
    public static int main() {
        println("=== UDP Socket测试 ===");
        
        /* 初始化网络库 */
        if (!NetworkUtils.init()) {
            println("网络库初始化失败");
            return 1;
        }
        println("网络库初始化成功");
        
        /* 创建UDP Socket */
        UdpSocket socket = new UdpSocket();
        println("UDP Socket创建成功");
        
        /* 绑定到本地端口 */
        int localPort = 12345;
        if (!socket.bindTo(localPort)) {
            println("绑定到端口失败: " + (String)localPort);
            NetworkUtils.cleanup();
            return 1;
        }
        println("成功绑定到端口: " + (String)localPort);
        
        /* 发送测试数据到本地地址（回环测试） */
        String testMessage = "Hello, UDP!";
        String targetIp = "127.0.0.1";
        int targetPort = 12346;  /* 不同的目标端口 */
        
        int sent = socket.sendTo(testMessage, targetIp, targetPort);
        if (sent > 0) {
            print("成功发送数据: ");
            println(testMessage);
            print("发送字节数: ");
            println((String)sent);
        } else {
            println("发送数据失败");
        }
        
        /* 短暂延迟，让数据包有时间被处理 */
        for (int i = 0; i < 100000; i = i + 1) {
            /* 忙等待 */
        }
        
        /* 测试接收功能 - 使用非阻塞模式 */
        SocketAddr senderAddr = new SocketAddr();
        String received = socket.receiveFrom(1024, senderAddr);
        if (received != null) {
            print("接收到数据: ");
            println(received);
        } else {
            println("未接收到数据（可能因为没有发送方）");
        }
        
        /* 关闭Socket */
        socket.close();
        println("Socket已关闭");
        
        /* 清理网络库 */
        NetworkUtils.cleanup();
        
        println("=== 测试完成 ===");
        return 0;
    }
}
