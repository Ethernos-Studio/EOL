/**
 * UDP通信测试示例
 * 
 * 演示如何使用Network库进行UDP通信
 * 版本: 0.5.1.0
 */

#include <Network.cay>

public int main() {
    println("=== UDP通信测试 ===");
    
    /* 初始化网络库 */
    if (!NetworkUtils.init()) {
        println("网络初始化失败");
        return 1;
    }
    
    println("网络初始化成功");
    
    /* 创建UDP Socket */
    UdpSocket socket = new UdpSocket();
    
    if (!socket.isValid()) {
        println("创建UDP Socket失败");
        NetworkUtils.cleanup();
        return 1;
    }
    
    println("UDP Socket创建成功");
    
    /* 绑定到本地端口 */
    int localPort = 12346;
    if (!socket.bindTo(localPort)) {
        println("绑定端口失败: " + localPort);
        socket.close();
        NetworkUtils.cleanup();
        return 1;
    }
    
    println("UDP Socket绑定到端口: " + localPort);
    
    /* 设置广播选项 */
    socket.setOption(SOL_SOCKET, SO_BROADCAST, 1);
    println("已启用广播选项");
    
    /* 发送UDP数据包到本地回环地址 */
    String message = "Hello, UDP!";
    String targetIp = "127.0.0.1";
    int targetPort = 12346;  /* 发送给自己用于测试 */
    
    println("发送UDP消息到: " + targetIp + ":" + targetPort);
    println("消息内容: " + message);
    
    int sent = socket.sendToIpPort(message, targetIp, targetPort);
    if (sent < 0) {
        println("发送失败");
    } else {
        println("发送成功，字节数: " + sent);
    }
    
    /* 接收UDP数据包 */
    println("等待接收UDP数据包...");
    
    SocketAddr fromAddr = new SocketAddr();
    String received = socket.receiveStringFrom(1024, fromAddr);
    
    if (received.length() > 0) {
        println("收到消息: " + received);
        println("发送方端口: " + NetworkUtils.ntohs(fromAddr.port));
    } else {
        println("未收到数据包");
    }
    
    /* 关闭Socket */
    socket.close();
    println("Socket已关闭");
    
    /* 清理网络库 */
    NetworkUtils.cleanup();
    
    println("=== 测试完成 ===");
    return 0;
}
