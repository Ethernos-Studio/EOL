{
  "name": "cavvy-analyzer",
  "displayName": "Cavvy Analyzer",
  "description": "Cavvy (EOL) 语言支持插件 - 语法高亮、跳转定义、语法错误提示、一键运行、LSP支持",
  "version": "0.3.0",
  "publisher": "ethernos-studio",
  "license": "GPL-3.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages",
    "Debuggers",
    "Linters",
    "Formatters"
  ],
  "keywords": [
    "cavvy",
    "eol",
    "language",
    "syntax",
    "highlight",
    "lsp"
  ],
  "activationEvents": [
    "onLanguage:cavvy"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "cavvy",
        "aliases": [
          "Cavvy",
          "EOL",
          "cavvy",
          "eol"
        ],
        "extensions": [
          ".cay",
          ".eol",
          ".caybc",
          ".ll"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/cavvy-icon.svg",
          "dark": "./icons/cavvy-icon.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "cavvy",
        "scopeName": "source.cavvy",
        "path": "./syntaxes/cavvy.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Cavvy Analyzer",
      "properties": {
        "cavvyAnalyzer.compilerPath": {
          "type": "string",
          "default": "cayc",
          "description": "Cavvy 编译器路径 (cayc)"
        },
        "cavvyAnalyzer.runnerPath": {
          "type": "string",
          "default": "cay-run",
          "description": "Cavvy 运行器路径 (cay-run)"
        },
        "cavvyAnalyzer.checkerPath": {
          "type": "string",
          "default": "cay-check",
          "description": "Cavvy 语法检查器路径 (cay-check)"
        },
        "cavvyAnalyzer.lspServerPath": {
          "type": "string",
          "default": "cay-lsp",
          "description": "Cavvy LSP 服务器路径 (cay-lsp)"
        },
        "cavvyAnalyzer.enableLSP": {
          "type": "boolean",
          "default": true,
          "description": "启用 LSP 语言服务器"
        },
        "cavvyAnalyzer.enableDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "启用语法错误诊断"
        },
        "cavvyAnalyzer.diagnosticDelay": {
          "type": "number",
          "default": 500,
          "description": "诊断延迟时间 (毫秒)"
        },
        "cavvyAnalyzer.runInTerminal": {
          "type": "boolean",
          "default": true,
          "description": "在终端中运行程序 (支持交互式输入)"
        },
        "cavvyAnalyzer.preserveFocus": {
          "type": "boolean",
          "default": false,
          "description": "运行程序时保持编辑器焦点"
        }
      }
    },
    "commands": [
      {
        "command": "cavvyAnalyzer.runCode",
        "title": "运行 Cavvy 代码",
        "category": "Cavvy",
        "icon": "$(play)"
      },
      {
        "command": "cavvyAnalyzer.runCodeNoDebug",
        "title": "运行 (非调试模式)",
        "category": "Cavvy",
        "icon": "$(play-circle)"
      },
      {
        "command": "cavvyAnalyzer.checkSyntax",
        "title": "检查 Cavvy 语法",
        "category": "Cavvy",
        "icon": "$(check)"
      },
      {
        "command": "cavvyAnalyzer.checkSyntaxManual",
        "title": "手动语法检查",
        "category": "Cavvy",
        "icon": "$(check-all)"
      },
      {
        "command": "cavvyAnalyzer.gotoDefinition",
        "title": "跳转到定义",
        "category": "Cavvy"
      },
      {
        "command": "cavvyAnalyzer.restartLSP",
        "title": "重启 LSP 服务器",
        "category": "Cavvy",
        "icon": "$(debug-restart)"
      },
      {
        "command": "cavvyAnalyzer.stopLSP",
        "title": "停止 LSP 服务器",
        "category": "Cavvy",
        "icon": "$(debug-stop)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "editorLangId == cavvy",
          "command": "cavvyAnalyzer.runCodeNoDebug",
          "group": "navigation@1"
        },
        {
          "when": "editorLangId == cavvy",
          "command": "cavvyAnalyzer.checkSyntaxManual",
          "group": "navigation@2"
        }
      ],
      "editor/context": [
        {
          "when": "editorLangId == cavvy",
          "command": "cavvyAnalyzer.runCodeNoDebug",
          "group": "navigation@1"
        },
        {
          "when": "editorLangId == cavvy",
          "command": "cavvyAnalyzer.checkSyntaxManual",
          "group": "navigation@2"
        },
        {
          "when": "editorLangId == cavvy",
          "command": "cavvyAnalyzer.gotoDefinition",
          "group": "navigation@3"
        }
      ],
      "commandPalette": [
        {
          "command": "cavvyAnalyzer.runCode",
          "when": "editorLangId == cavvy"
        },
        {
          "command": "cavvyAnalyzer.runCodeNoDebug",
          "when": "editorLangId == cavvy"
        },
        {
          "command": "cavvyAnalyzer.checkSyntaxManual",
          "when": "editorLangId == cavvy"
        }
      ]
    },
    "keybindings": [
      {
        "command": "cavvyAnalyzer.runCodeNoDebug",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "editorTextFocus && editorLangId == cavvy"
      },
      {
        "command": "cavvyAnalyzer.checkSyntaxManual",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "when": "editorTextFocus && editorLangId == cavvy"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "typescript": "^5.2.0",
    "@vscode/vsce": "^2.21.0"
  }
}
