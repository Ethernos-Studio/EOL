{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Cavvy",
  "scopeName": "source.cavvy",
  "fileTypes": [".cay", ".eol", ".caybc", ".ll"],
  "patterns": [
    {
      "include": "#preprocessor"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#annotations"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#primitive-types"
    },
    {
      "include": "#ffi-types"
    },
    {
      "include": "#control-flow"
    },
    {
      "include": "#literals"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#chars"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#builtin-functions"
    },
    {
      "include": "#method-calls"
    },
    {
      "include": "#class-declaration"
    },
    {
      "include": "#interface-declaration"
    },
    {
      "include": "#method-declaration"
    },
    {
      "include": "#extern-declaration"
    },
    {
      "include": "#lambda-expressions"
    },
    {
      "include": "#method-references"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "preprocessor": {
      "patterns": [
        {
          "name": "meta.preprocessor.cavvy",
          "match": "^(\\s*)(#)(define|ifdef|ifndef|endif|undef|if|elif|else|pragma|include|error|warning)(\\s+)(.*)$",
          "captures": {
            "1": {
              "name": "punctuation.whitespace.preprocessor.leading.cavvy"
            },
            "2": {
              "name": "punctuation.definition.preprocessor.cavvy"
            },
            "3": {
              "name": "keyword.control.preprocessor.cavvy"
            },
            "4": {
              "name": "punctuation.whitespace.preprocessor.cavvy"
            },
            "5": {
              "name": "entity.name.function.preprocessor.cavvy",
              "patterns": [
                {
                  "include": "#strings"
                },
                {
                  "include": "#numbers"
                },
                {
                  "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b",
                  "name": "entity.name.function.preprocessor.cavvy"
                }
              ]
            }
          }
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.block.cavvy",
          "begin": "/\\*",
          "end": "\\*/",
          "captures": {
            "0": {
              "name": "punctuation.definition.comment.cavvy"
            }
          }
        },
        {
          "name": "comment.line.double-slash.cavvy",
          "begin": "//",
          "end": "$",
          "captures": {
            "0": {
              "name": "punctuation.definition.comment.cavvy"
            }
          }
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "storage.modifier.annotation.cavvy",
          "match": "@\\s*[a-zA-Z_][a-zA-Z0-9_]*",
          "captures": {
            "0": {
              "name": "entity.name.function.decorator.cavvy"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.cavvy",
          "match": "\\b(if|else|while|for|do|switch|case|default|break|continue|return|new|scope)\\b"
        },
        {
          "name": "keyword.other.cavvy",
          "match": "\\b(class|void|this|super|null|final|static|abstract|native|public|private|protected|extends|implements|interface|enum|package|import|namespace|extern|auto|var|let|instanceof)\\b"
        }
      ]
    },
    "modifiers": {
      "patterns": [
        {
          "name": "storage.modifier.cavvy",
          "match": "\\b(public|private|protected|static|final|abstract|native|Override)\\b"
        }
      ]
    },
    "primitive-types": {
      "patterns": [
        {
          "name": "storage.type.primitive.cavvy",
          "match": "\\b(int|long|float|double|bool|boolean|char|string|void|auto)\\b"
        }
      ]
    },
    "ffi-types": {
      "patterns": [
        {
          "name": "storage.type.ffi.cavvy",
          "match": "\\b(c_int|c_long|c_short|c_char|c_byte|c_float|c_double|c_bool|c_void|size_t|ssize_t|uintptr_t|intptr_t|uint8_t|uint16_t|uint32_t|uint64_t|int8_t|int16_t|int32_t|int64_t)\\b"
        }
      ]
    },
    "control-flow": {
      "patterns": [
        {
          "name": "keyword.control.conditional.cavvy",
          "match": "\\b(if|else|switch|case|default)\\b"
        },
        {
          "name": "keyword.control.loop.cavvy",
          "match": "\\b(while|for|do|break|continue)\\b"
        },
        {
          "name": "keyword.control.return.cavvy",
          "match": "\\b(return)\\b"
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "name": "constant.language.boolean.cavvy",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.cavvy",
          "match": "\\b(null)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.cavvy",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.cavvy",
          "match": "\\\\(n|t|r|\\\\|\"|'|b|f|0|u[0-9a-fA-F]{4})"
        }
      ]
    },
    "chars": {
      "name": "string.quoted.single.cavvy",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "name": "constant.character.escape.cavvy",
          "match": "\\\\(n|t|r|\\\\|\"|'|b|f|0|u[0-9a-fA-F]{4})"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.cavvy",
          "match": "\\b0[xX][0-9a-fA-F_]+[Ll]?\\b"
        },
        {
          "name": "constant.numeric.binary.cavvy",
          "match": "\\b0[bB][01_]+[Ll]?\\b"
        },
        {
          "name": "constant.numeric.octal.cavvy",
          "match": "\\b0[oO][0-7_]+[Ll]?\\b"
        },
        {
          "name": "constant.numeric.float.cavvy",
          "match": "\\b-?(?:\\d[\\d_]*\\.\\d[\\d_]*|\\.\\d[\\d_]*|\\d[\\d_]*\\.?)(?:[eE][+-]?\\d[\\d_]*)?[FfDd]?\\b"
        },
        {
          "name": "constant.numeric.integer.cavvy",
          "match": "\\b-?\\d[\\d_]*[Ll]?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.cavvy",
          "match": "(\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=|>>>=|=)"
        },
        {
          "name": "keyword.operator.logical.cavvy",
          "match": "(\\|\\||&&|!)"
        },
        {
          "name": "keyword.operator.bitwise.cavvy",
          "match": "(\\||&|\\^|~|<<|>>>|>>)"
        },
        {
          "name": "keyword.operator.comparison.cavvy",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.arithmetic.cavvy",
          "match": "(\\+|-\\+|--?|\\*|/|%)"
        },
        {
          "name": "keyword.operator.varargs.cavvy",
          "match": "\\.\\.\\."
        },
        {
          "name": "keyword.operator.lambda.cavvy",
          "match": "->"
        },
        {
          "name": "keyword.operator.method-reference.cavvy",
          "match": "::"
        },
        {
          "name": "keyword.operator.ternary.cavvy",
          "match": "\\?|:"
        }
      ]
    },
    "builtin-functions": {
      "patterns": [
        {
          "name": "support.function.builtin.cavvy",
          "match": "\\b(print|println|printf|readInt|readLong|readFloat|readDouble|readLine|readChar|parseInt|parseLong|parseFloat|parseDouble)\\s*(?=\\()"
        },
        {
          "name": "support.function.builtin.cavvy",
          "match": "\\b(length|substring|indexOf|replace|charAt|toLowerCase|toUpperCase|trim|startsWith|endsWith|contains|concat|equals|isEmpty|compareTo|valueOf)\\s*(?=\\()"
        }
      ]
    },
    "method-calls": {
      "patterns": [
        {
          "name": "meta.method-call.cavvy",
          "begin": "(\\.)\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\()",
          "beginCaptures": {
            "1": {
              "name": "punctuation.accessor.cavvy"
            },
            "2": {
              "name": "entity.name.function.member.cavvy"
            },
            "3": {
              "name": "punctuation.definition.arguments.begin.cavvy"
            }
          },
          "end": "\\)",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.arguments.end.cavvy"
            }
          },
          "patterns": [
            {
              "include": "$self"
            }
          ]
        },
        {
          "name": "meta.field-access.cavvy",
          "match": "(\\.)\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "punctuation.accessor.cavvy"
            },
            "2": {
              "name": "variable.other.property.cavvy"
            }
          }
        }
      ]
    },
    "class-declaration": {
      "patterns": [
        {
          "name": "meta.class.declaration.cavvy",
          "begin": "\\b(class)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?::\\s*([a-zA-Z_][a-zA-Z0-9_]*)|\\s+extends\\s+([a-zA-Z_][a-zA-Z0-9_]*))?\\s*",
          "beginCaptures": {
            "1": {
              "name": "storage.type.class.cavvy"
            },
            "2": {
              "name": "entity.name.type.class.cavvy"
            },
            "3": {
              "name": "entity.name.type.class.parent.cavvy"
            },
            "4": {
              "name": "entity.name.type.class.parent.cavvy"
            }
          },
          "end": "(?=\\{)",
          "patterns": [
            {
              "include": "#modifiers"
            },
            {
              "match": "\\b(implements)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
              "captures": {
                "1": {
                  "name": "keyword.other.cavvy"
                },
                "2": {
                  "name": "entity.name.type.interface.cavvy"
                }
              }
            }
          ]
        }
      ]
    },
    "interface-declaration": {
      "patterns": [
        {
          "name": "meta.interface.declaration.cavvy",
          "begin": "\\b(interface)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*",
          "beginCaptures": {
            "1": {
              "name": "storage.type.interface.cavvy"
            },
            "2": {
              "name": "entity.name.type.interface.cavvy"
            }
          },
          "end": "(?=\\{)",
          "patterns": [
            {
              "include": "#modifiers"
            },
            {
              "match": "\\b(extends)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
              "captures": {
                "1": {
                  "name": "keyword.other.cavvy"
                },
                "2": {
                  "name": "entity.name.type.interface.parent.cavvy"
                }
              }
            }
          ]
        }
      ]
    },
    "method-declaration": {
      "patterns": [
        {
          "name": "meta.method.declaration.cavvy",
          "begin": "\\b((?:(?:public|private|protected|static|final|abstract|native)\\s+)*)((?:int|long|float|double|bool|char|void|[a-zA-Z_][a-zA-Z0-9_]*))\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\()",
          "beginCaptures": {
            "1": {
              "name": "storage.modifier.cavvy"
            },
            "2": {
              "name": "storage.type.primitive.cavvy"
            },
            "3": {
              "name": "entity.name.function.cavvy"
            },
            "4": {
              "name": "punctuation.definition.parameters.begin.cavvy"
            }
          },
          "end": "\\)",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.parameters.end.cavvy"
            }
          },
          "patterns": [
            {
              "include": "#primitive-types"
            },
            {
              "include": "#ffi-types"
            },
            {
              "include": "#identifiers"
            },
            {
              "include": "#operators"
            },
            {
              "match": "\\.\\.\\.",
              "name": "keyword.operator.varargs.cavvy"
            }
          ]
        }
      ]
    },
    "extern-declaration": {
      "patterns": [
        {
          "name": "meta.extern.declaration.cavvy",
          "begin": "\\b(extern)\\s+(?:(cdecl|stdcall|fastcall|thiscall|vectorcall|sysv64|win64|aapcs|msp430)\\s+)?\\{",
          "beginCaptures": {
            "1": {
              "name": "keyword.other.cavvy"
            },
            "2": {
              "name": "storage.modifier.calling-convention.cavvy"
            }
          },
          "end": "\\}",
          "patterns": [
            {
              "include": "#ffi-types"
            },
            {
              "include": "#primitive-types"
            },
            {
              "include": "#identifiers"
            }
          ]
        }
      ]
    },
    "lambda-expressions": {
      "patterns": [
        {
          "name": "meta.lambda.expression.cavvy",
          "begin": "(\\([^)]*\\)|[a-zA-Z_][a-zA-Z0-9_]*)\\s*(->)",
          "beginCaptures": {
            "1": {
              "name": "meta.lambda.parameters.cavvy"
            },
            "2": {
              "name": "keyword.operator.lambda.cavvy"
            }
          },
          "end": "(?=[;,})]|$)",
          "patterns": [
            {
              "include": "$self"
            }
          ]
        }
      ]
    },
    "method-references": {
      "patterns": [
        {
          "name": "meta.method.reference.cavvy",
          "match": "([a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)*|this|super)(::)([a-zA-Z_][a-zA-Z0-9_]*|new)",
          "captures": {
            "1": {
              "name": "entity.name.type.class.cavvy"
            },
            "2": {
              "name": "keyword.operator.method-reference.cavvy"
            },
            "3": {
              "name": "entity.name.function.cavvy"
            }
          }
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.readwrite.cavvy",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
